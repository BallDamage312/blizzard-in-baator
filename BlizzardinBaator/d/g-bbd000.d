Kill("Ravel") CreateCreature("Ravel",[0.0],1) Kill("Ravel") ActionOverride("Ravel",DestroySelf())~ + g-bbD000.classes
IF~Global("G-JOINS","GLOBAL",1)~THEN REPLY @5 /*Modify your party. */ DO~~ + g-bbD000.team
IF~Global("G-Blast_return","GLOBAL",1) ~THEN REPLY @6 /*"What else do you have for me, zombie?" */ DO~SetGlobal("G-JOINS","GLOBAL",1) SetGlobal("G-joiningblast","GLOBAL",0) StartStore("g-bb#000",Protagonist)~ EXIT
IF~Global("G-joiningblast","GLOBAL",0)~THEN REPLY @7 /*Leave. */ DO~~ EXIT
CHAIN IF~~THEN g-bbD000 g-bbD000.classes
@9 /*A flood of questions enters your mind, some of which seem important. You struggle with the abundance of intrusive thoughts, but after a moment's reflection, you manage to organize them. Even though you are just talking to a zombie, the questions feel as though they are coming from the deepest recesses of your own mind. [SPTR_01] */
=@10 /*"A person's profession and personality often define them. What principles have guided your life? What was your occupation?" */
END
IF~~THEN REPLY @12 /*"Only the strongest will prevail. I was a fighter." */ DO~SetNamelessClass(FIGHTER) ChangeStat(Protagonist,CHR,5,ADD) ChangeStat(Protagonist,WIS,3,ADD) AddXPObject(Protagonist,2000000)~ + g-bbD000.characters
IF~~THEN REPLY @13 /*"I was guided by knowledge and I trusted in the Art. I was a mage." */ DO~SetNamelessClass(MAGE) GiveItemCreate("EYEKAL",Protagonist,0,0,0) GiveItemCreate("DAG1",Protagonist,0,0,0)  GiveItemCreate("AMBEAR",Protagonist,0,0,0) GiveItemCreate("BBWAND",Protagonist,0,0,0) GiveItemCreate("BBCHRM",Protagonist,0,0,0) ChangeStat(Protagonist,CHR,5,ADD) ChangeStat(Protagonist,INT,1,ADD) ChangeStat(Protagonist,WIS,3,ADD) AddXPObject(Protagonist,2250000)~ + g-bbD000.characters
IF~~THEN REPLY @14 /*"A knife in the back? I'm no stranger to it. I was a thief." */ DO~SetNamelessClass(THIEF) GiveItemCreate("THIEF1",Protagonist,0,0,0) GiveItemCreate("THIEF2",Protagonist,0,0,0) ChangeStat(Protagonist,CHR,5,ADD) ChangeStat(Protagonist,WIS,3,ADD) AddXPObject(Protagonist,1600000)~ + g-bbD000.characters
CHAIN IF~~THEN g-bbD000 g-bbD000.characters
@16 /*"What ideas guided your path?" */
END
