SetGlobal("GOOD","GLOBAL",15)
ChangeAlignment(Protagonist,LAWFUL_GOOD)~ + g-bbD000.main.quests.journal.pharod
IF~~THEN REPLY @19 /*"Empathy and altruism." (Neutral Good) */ DO~SetGlobal("LAW","GLOBAL",0)
SetGlobal("GOOD","GLOBAL",15)
ChangeAlignment(Protagonist,NEUTRAL_GOOD)~ + g-bbD000.main.quests.journal.pharod
