// Portal from ARG-P4

IF
    HarmlessEntered("Nordom")
THEN
    RESPONSE #100
        VerbalConstant("Nordom",NORDOM_PORTAL)
        Continue()
END

IF
	 HarmlessEntered([PC])
THEN
	RESPONSE #100
		SetPortalCursor("G-TOE1",PORTAL_CURSOR_VISIBLE,TRUE)
        SetPortalCursor("G-TOE1",PORTAL_ENABLED,TRUE)
END