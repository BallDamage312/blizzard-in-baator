	HarmlessEntered([PC])
	PartyHasItem("g-bbi091")  // Jade Skull
THEN
	RESPONSE #100
		SetPortalCursor("G-TOP5",PORTAL_CURSOR_VISIBLE,TRUE)
		SetPortalCursor("G-TOP5",PORTAL_ENABLED,TRUE)
END

