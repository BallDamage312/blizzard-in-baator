// Ignus Join
 
IF
  True()
THEN
  RESPONSE #100
	CutSceneId(Player1)
    StartCutSceneMode()
	UndoExplore()
	FadeToColor([10.0],0)
	SmallWait(3)
	MoveViewPoint([1160.2420],INSTANT)
    ActionOverride("Ignus",JoinParty())
	SmallWait(2)
	ActionOverride("Ignus",AddXPObject("Ignus",600000))
	SmallWait(2)
	TeleportParty("AR0202",[1160.2420],14)
	EndCutSceneMode()
END
