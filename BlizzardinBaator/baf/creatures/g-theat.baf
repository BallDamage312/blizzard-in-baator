		Global("G-allegianceset","LOCALS",1)
		Global("g-raidallegiances","GLOBAL",4)
THEN
	RESPONSE #100
	Enemy()
		Attack(Protagonist)  END
		
		
		IF
	!ActuallyInCombat()
THEN
    RESPONSE #10
		ReturnToSavedPlace()
		PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100262) 
        WaitRandom(6,16)
        Continue()
	RESPONSE #10
        ReturnToSavedPlace()
        PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100263) 
		WaitRandom(6,16)
        Continue()
	RESPONSE #10
        ReturnToSavedPlace()
        PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100264)
		WaitRandom(6,16)
        Continue()
	RESPONSE #10
        ReturnToSavedPlace()
        PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100265)
		WaitRandom(6,16)
        Continue()
	RESPONSE #10
        ReturnToSavedPlace()
        PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100266)
		WaitRandom(6,16)
        Continue()
	RESPONSE #10
        ReturnToSavedPlace()
        PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100267)
		WaitRandom(6,16)
        Continue()
	RESPONSE #30
        ReturnToSavedPlace()
		WaitRandom(10,21)
        Continue()
END
