IF
GlobalGT("G-ulfbrandwonagainstus","GLOBAL",0)
THEN
	RESPONSE #100
EscapeArea()
END

IF
GlobalGT("G-ulfbrandlostraid","GLOBAL",0)
THEN
	RESPONSE #100
EscapeArea()
END

IF
GlobalGT("G-ulfbrandwonraid","GLOBAL",0)
THEN
	RESPONSE #100
EscapeArea()
END



IF
    Global("G-raeliscrisis","GLOBAL",1)
THEN
    RESPONSE #100
	StartCutSceneMode()
    CutSceneId(Player1)
    MoveToPoint([820.736])
    Wait(2)
	ActionOverride("G-bb190",StartDialogueNoSet("G-bbd190"))
    EndCutSceneMode()
	
END

IF
    Global("G-raeliscrisis","GLOBAL",2)
	Global("G-raeliscrisisX","GLOBAL",0)
THEN
    RESPONSE #100
	SetGlobal("G-raeliscrisisX","GLOBAL",1)
	StartCutSceneMode()
    CutSceneId(Player1)
    MoveToPoint([1141.621])
    Wait(2)
	EndCutSceneMode()
	ActionOverride("G-bb190",StartDialogueNoSet("G-bbd190"))
    
	
END
// Random, when attacked 
 
IF
    Help([ANYONE])
    Team(LastTrigger,G-FWRAID_DG)
THEN
    RESPONSE #100
        Enemy()
		Attack(NearestEnemyOf(Myself))
END 

IF
	GlobalGT("G-theaterraided","GLOBAL",0)
THEN
RESPONSE #100
	ChangeTeam(Myself,G-FWRAID_F)
	Help()
END 
 
IF
	GlobalGT("G-raidberserk","GLOBAL",0)
	!GlobalGT("G-ulfbrandwonagainstus","GLOBAL",0)
	!GlobalGT("G-ulfbrandlostraid","GLOBAL",0)
	!GlobalGT("G-ulfbrandwonraid","GLOBAL",0)
THEN
	RESPONSE #60
		Wait(5)
	ForceSpell(NearestEnemyOf(Myself),WIZARD_CHROMATIC_ORB)
	RESPONSE #20
		Wait(5)
	ForceSpell(Myself,WIZARD_BLUR) 
		RESPONSE #20
		Wait(5)
	ForceSpell(FarthestEnemyOf(Myself),WIZARD_HORROR)	
END  
 
 
IF

	Global("G-theaterabandoned","GLOBAL",1)
	AreaCheck("arg-08")
THEN
	RESPONSE #100
		DestroySelf()
 END

