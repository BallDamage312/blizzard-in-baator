	Global("g-kuotoakiaran","GLOBAL",0)
    Global("g-kuotoabhaal","GLOBAL",0)
	Global("g-kuotoagod","GLOBAL",0)
	!ActuallyInCombat()
	
THEN
    RESPONSE #100
		ReturnToSavedPlace()
		PlaySequence(ANIM_TALK)
        FloatMessage(Myself,@100034) 
