IF
    See([PC])
    GlobalGT("G-Ratshaman_Kombat_001","LOCALS",8)
THEN
    RESPONSE #100
        ForceSpell(NearestAllyOf(Myself),CLERIC_PRAYER)
        RunningAttack(NearestEnemyOf(Myself))
END

IF
    Global("g-squerrikalert","GLOBAL",1)
THEN
    RESPONSE #100
        FaceObject([PC])
        Help()
        Enemy()
        SetGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END

IF
    HPPercentLT("g-bb242",50)
THEN
    RESPONSE #100
        ForceSpell(Myself,CLERIC_CURE_SERIOUS_WOUNDS)
        RunningAttack(NearestEnemyOf(Myself))
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END
