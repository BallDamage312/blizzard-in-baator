IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",8)
THEN
    RESPONSE #100
        ForceSpell([PC],WIZARD_IGNUS_FORCE_MISSILES)
        //RunningAttack(NearestEnemyOf(Myself))
