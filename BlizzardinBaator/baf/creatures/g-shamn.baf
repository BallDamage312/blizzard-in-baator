IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",4)
THEN
    RESPONSE #100
        ForceSpell(LastSeenBy(Myself),WIZARD_CLOUDKILL)
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END

IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",5)
THEN
    RESPONSE #100
        ForceSpell(NearestAllyOf(Myself),CLERIC_AID)
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END

