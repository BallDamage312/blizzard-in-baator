IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",7)
THEN
    RESPONSE #100
        ForceSpell(NearestAllyOf(Myself),WIZARD_BLOOD_BRIDGE)
        //RunningAttack(NearestEnemyOf(Myself))
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
