
IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",1)
THEN
    RESPONSE #100
        ForceSpell([PC],CLERIC_CURSE) 
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END

IF
     See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",2)
THEN
    RESPONSE #100
        ForceSpell([PC],WIZARD_VAMPIRIC_TOUCH)
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
END

IF
    See([PC])
    Global("G-Ratshaman_Kombat_001","LOCALS",3)
THEN
    RESPONSE #100
        ForceSpell([PC],WIZARD_SWARM_CURSE)
        IncrementGlobal("G-Ratshaman_Kombat_001","LOCALS",1)
