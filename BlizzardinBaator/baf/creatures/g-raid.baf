IF
GlobalGT("G-ulfbrandwonagainstus","GLOBAL",0)
THEN
	RESPONSE #75
EscapeArea()
	RESPONSE #25
Kill(Myself)
END

IF
GlobalGT("G-ulfbrandlostraid","GLOBAL",0)
THEN
	RESPONSE #50
EscapeArea()
	RESPONSE #50
Kill(Myself)
END

IF
GlobalGT("G-ulfbrandwonraid","GLOBAL",0)
THEN
	RESPONSE #75
EscapeArea()
	RESPONSE #25
Kill(Myself)
END

IF
	Global("g-raidendedwhendead","GLOBAL",1)

THEN
	RESPONSE #100
		DestroySelf()
END

IF
    OnCreation()
THEN
    RESPONSE #100
        ChangeTeam(Myself,G-FWRAID_F)
END

IF
Global("g-raidberserk","GLOBAL",1) 
THEN
    RESPONSE #100
	RunningAttack([0.0.0.0.G-RAID_DOOM])
	Continue()
END

