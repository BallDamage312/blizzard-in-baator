IF
		Global("G-allegianceset","LOCALS",0)
		OR(2) Global("g-raidallegiances","GLOBAL",1) Global("g-raidallegiances","GLOBAL",2)
THEN
	RESPONSE #25
		ChangeEnemyAlly(Myself,NEUTRAL)
		Attack("g-bb017")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()
	RESPONSE #25
		ChangeEnemyAlly(Myself,NEUTRAL)
		Attack("g-bb042")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()
	RESPONSE #25
		ChangeEnemyAlly(Myself,NEUTRAL)
		Attack("g-bb060")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()
	RESPONSE #25
		ChangeEnemyAlly(Myself,NEUTRAL)
		Attack("g-bb203")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()	
END

IF
		Global("G-allegianceset","LOCALS",0)
		OR(2) Global("g-raidallegiances","GLOBAL",3) Global("g-raidallegiances","GLOBAL",4)
THEN
	RESPONSE #35
		Enemy()
		Attack("g-bb017")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()
	RESPONSE #15
		Enemy()
		Attack("g-bb042")
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()
	RESPONSE #50
		Enemy()
		Attack(Protagonist)
		SetGlobal("G-allegianceset","LOCALS",1)
		Continue()	
END

