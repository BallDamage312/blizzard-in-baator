IF
GlobalGT("G-ulfbrandwonagainstus","GLOBAL",0)
THEN
	RESPONSE #25
EscapeArea()
	RESPONSE #75
Kill(Myself)
END


IF
GlobalGT("G-ulfbrandlostraid","GLOBAL",0)
THEN
	RESPONSE #100
EscapeArea()
END

IF
GlobalGT("G-ulfbrandwonraid","GLOBAL",0)
THEN
	RESPONSE #75
EscapeArea()
	RESPONSE #25
Kill(Myself)
END

IF
	Global("g-raidendedwhendead","GLOBAL",1)

THEN
	RESPONSE #75
	EscapeArea()
	RESPONSE #25
	Kill(Myself)
END
// Random, when attacked 

IF

Global("g-raidberserk","GLOBAL",1) 
Global("g-doomguardpounce","LOCALS",1)
THEN
    RESPONSE #100
	FaceObject([0.0.0.0.G-RAID_FATED])
        RunningAttack([0.0.0.0.G-RAID_FATED])
		//Enemy()
        Continue()
	
END

IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
    RunningAttack(NearestEnemyOf(Myself))
END

IF
    AttackedBy([PC],DEFAULT)
THEN
    RESPONSE #100
		FaceObject([PC])
		Enemy()
		Help()
		RunningAttack(NearestEnemyOf(Myself))
END

IF
    Help([0.0.0.0.G-RAID_DOOM])
THEN
    RESPONSE #100
        Enemy()
        RunningAttack(LastAttackerOf(LastHelp))
END
 
IF
    Help([ANYONE])
    Team(LastTrigger,G-RAID_DOOM)
THEN
    RESPONSE #100
        Enemy()
		Attack(NearestEnemyOf(Myself))
END 


IF
    OnCreation()
THEN
    RESPONSE #100
        ChangeTeam(Myself,G-FWRAID_DG)
END

