// Kabatum


IF
    OnCreation()
THEN
    RESPONSE #100
        FaceObject([PC])
        SetItemFlags("COPPER",NONSTEALABLE,TRUE)
        SetItemFlags("HEARCHRM",NONSTEALABLE,TRUE)
        Continue()
END

IF
    //See(NearestEnemyOf(Myself))
    HPPercentLT(Myself,55)
    HasItem("HEARCHRM",Myself)

THEN
    RESPONSE #100
        UseItem("HEARCHRM",Myself)  
        FloatMessage(Myself,30539)
		FaceObject([PC])
		RunningAttack(NearestEnemyOf(Myself))
END

IF	
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",1)
THEN
    RESPONSE #100
        ForceSpell(Myself,WIZARD_CLOAK_OF_WARDING)
		Wait(1)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

IF
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",2)
THEN
    RESPONSE #100
        Spell([PC],WIZARD_MAGIC_MISSILE)
        Wait(1)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

