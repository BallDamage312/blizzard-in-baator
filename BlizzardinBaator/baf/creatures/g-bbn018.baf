THEN
    RESPONSE #100
		FloatMessage(Myself,@100013)
        Spell([PC],WIZARD_FORCE_MISSILES)
        Wait(1)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

