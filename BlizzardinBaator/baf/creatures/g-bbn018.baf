/*
IF
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",9)
THEN
    RESPONSE #100
        Spell([PC],WIZARD_FIRE_AND_ICE)
        Wait(1)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END
*/
IF
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",9)
THEN
    RESPONSE #100
        ForceSpellRES("g-bb668",NearestEnemyOf(Myself))
        IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

IF
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",10)
THEN
    RESPONSE #100
		FloatMessage(Myself,@100011)
        ReallyForceSpell(Myself,WIZARD_BLUR)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

IF
	See(NearestEnemyOf(Myself))
	Global("G-Kabatum_Kombat_N018","LOCALS",11)
THEN
    RESPONSE #100
        Spell(Myself,WIZARD_STRENGTH)
		ForceSpellRES("g-bb686",Myself)
		IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

IF
	See(NearestEnemyOf(Myself))
    GlobalGT("G-Kabatum_Kombat_N018","LOCALS",11)
THEN
    RESPONSE #100
        RunningAttack(NearestEnemyOf(Myself))
END

IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
    Enemy()
	RunningAttack(NearestEnemyOf(Myself))
	IncrementGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END

IF
    AttackedBy([PC],DEFAULT)
THEN
    RESPONSE #100
		FaceObject([PC])
		FloatMessage(Myself,@100012)
		Enemy()
		Wait(1)
		SetGlobal("G-Kabatum_Kombat_N018","LOCALS",1)
END
