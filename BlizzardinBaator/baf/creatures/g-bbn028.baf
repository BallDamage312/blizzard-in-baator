IF
	GlobalGT("G-Kocachron_Kombat_N028","LOCALS",2)
	See(NearestEnemyOf(Myself))
   
THEN
    RESPONSE #100
        RunningAttack(NearestEnemyOf(Myself))
END

IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
    //Enemy()
	IncrementGlobal("G-Kocachron_Kombat_N028","LOCALS",1)
END
*/
IF
    AttackedBy([PC],DEFAULT)
THEN
    RESPONSE #100
		FaceObject([PC])
		Enemy()
		Help()
		SetGlobal("G-Kocachron_Kombat_N028","LOCALS",1)
END

IF
    Help([0.0.0.0.G-KOCACHRON_R2])
THEN
    RESPONSE #100
        Enemy()
		ForceSpell([PC],WIZARD_ADDERS_KISS)
        RunningAttack(LastAttackerOf(LastHelp))
END

IF
	True()
THEN
	RESPONSE #100
		RandomWalk()
		Continue()
END