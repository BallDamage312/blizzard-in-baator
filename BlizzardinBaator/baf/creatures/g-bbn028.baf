// Kocachron - the ditch arg-r2 fight with thug_r2

IF
    OnCreation()
THEN
    RESPONSE #100
		FaceObject([0.0.0.0.G-THUG_R2])
		ForceSpell(Myself,WIZARD_PAIN_MIRROR)
        ForceSpell([0.0.0.0.G-THUG_R2],WIZARD_ADDERS_KISS)
		RunningAttack([0.0.0.0.G-THUG_R2])
		//Enemy()
        Continue()
END
/*
IF	
	Global("G-Kocachron_Kombat_N028","LOCALS",1)
	See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
        ForceSpell(Myself,WIZARD_PAIN_MIRROR)
