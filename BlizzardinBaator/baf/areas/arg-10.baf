// Fake FFG dialogue

IF
    InParty("Grace")
	!StateCheck("Grace",CD_STATE_NOTVALID)
	Global("G-fakeffgdial002triggered","GLOBAL",0) // one time trigger
THEN
    RESPONSE #100
	Wait(8)
	SetGlobal("G-fakeffgdial002triggered","GLOBAL",1) // one time trigger
	SetGlobal("g-fakeffgdialogue","GLOBAL",2) // fake dialog selection
	CreateCreatureObject("g-bbFFG",Player1,0,0,0) // fake FFG creation
	ActionOverride("g-bbFFG",StartDialog("g-bbdFFG",Player1)) // Fake FFG dialogue initiation
END



IF
	HPPercentLT("g-bb007",30)
	Global("G-Bard_Ambush_Fight","Global",2)
THEN
	RESPONSE #100
		ActionOverride("g-bb007",StartDialogNoSet(Player1))
		SetGlobal("G-Bard_Ambush_Fight","Global",3)
END

IF
    Global("G-demoend","Global",1)
THEN
    RESPONSE #100
        FadeFromColor([20.0],0)
        SetGlobal("G-demoend","Global",2)
        StartCutSceneMode()
        StartCutScene("g-bbc017")
END

