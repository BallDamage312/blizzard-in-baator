IF
    Global("G-Dummy_Cania_Portal_2","GLOBAL",1)	
THEN
    RESPONSE #100
        TriggerActivation("G-pt",FALSE)
        SetGlobal("G-Dummy_Cania_Portal_2","GLOBAL",2)
		Continue()
END

IF
    Global("G-BBfreezing","GLOBAL",1)
THEN
    RESPONSE #100
	SetGlobal("G-BBfreezing","GLOBAL",2)
	SetGlobal("Game_Over","GLOBAL",2)
END

IF
  True()
THEN
    RESPONSE #100
        SetWorldmap("G-CANIA")
	Continue()
END


IF
    Global("G-BBfreezing","GLOBAL",0)
THEN
    RESPONSE #100
	StartMovie("g-cania")
	SetGlobal("G-BBfreezing","GLOBAL",10)
	Explore()
END

