// SOLVING HORROR

IF
	OR(4)
	Global("G-kuotoaprisonersfree","GLOBAL",1)
	Global("g-kuotoadead","GLOBAL",1)
	Global("g-kuotoagone","GLOBAL",1)
	Global("g-kuotoaraid","GLOBAL",1)
THEN
    RESPONSE #100
		ActionOverride("g-bb170",EscapeArea())
		Continue()
END

IF
    !Global("G-kuotoaquestline","GLOBAL",15)
	OR(2)
	Global("g-kuotoadead","GLOBAL",1)
	Global("g-kuotoagone","GLOBAL",1)
	
THEN
    RESPONSE #100
        SetGlobal("G-kuotoaquestline","GLOBAL",15)
        DisplayString(Player1, @100196)
		PlaySound("NAM157")
		Continue()
END

// KILLIN KILTHAS AND HIS NEW CULT

IF
    Global("g-kuotoabhaal","GLOBAL",1)
	Global("g-dopilpdied","GLOBAL",1)
	Global("g-kilthasdied","GLOBAL",1)
THEN
    RESPONSE #100
        SetGlobal("G-kuotoaquestline","GLOBAL",16)
        DisplayString(Player1, @100196)
		PlaySound("NAM157")
		SetGlobal("g-kuotoabhaal","GLOBAL",0)
END
