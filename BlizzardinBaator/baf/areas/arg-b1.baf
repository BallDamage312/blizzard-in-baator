    Global("g-FWRAID","GLOBAL",1)
	Global("g-FWRAIDa","GLOBAL",0)
THEN
    RESPONSE #100
        CreateCreatureObject("g-bb190",Protagonist,0,0,0)
        CreateCreatureObject("g-bb156",Protagonist,0,0,0)
	ActionOverride("g-bb190",StartDialog("g-bbd190",Protagonist))
	StartCutSceneMode()
	CutSceneId(Player1)
	EndCutSceneMode()
        SetGlobal("g-FWRAIDa","GLOBAL",1)
		Continue()
END