IF
    True()
THEN
    RESPONSE #100
        SetWorldmap("G-DITCH")
		Explore()
		Continue()
END

IF
    Global("G-AmbushGraceDead","GLOBAL",1)
THEN
    RESPONSE #100
		Kill("GRACE")
		SetGlobal("G-AmbushGraceDead","GLOBAL",0)
		Continue()
END

