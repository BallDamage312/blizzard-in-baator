IF
    Global("G-D1cutscene","GLOBAL",1)
THEN
    RESPONSE #100

        SetGlobal("g-trapvictoryloop","GLOBAL",3)
		CreateCreature("g-bb017",[147.1478],0)
        CreateCreature("g-bb054",[235.1557],0)
        CreateCreature("g-bb201",[531.1334],0)
		ActionOverride("g-bb201",SetDialogue("g-bbd156"))
        ActionOverride("g-bb201",ChangeEnemyAlly(Myself,NEUTRAL))
		//CreateCreature("g-bb189",[531.1334],0)
        //StartDialog("g-bbd189",Player1)
        ActionOverride("g-bb201",StartDialogNoSet("g-bbd156"))
        SetGlobal("G-D1cutscene","GLOBAL",0)
		ActionOverride("g-bb201",ChangeEnemyAlly(Myself,ENEMY))
		//ActionOverride("g-bb189",DestroySelf())
        Continue()
END


IF
    Dead("g-bb201")
    Global("g-trapvictoryloop","GLOBAL",3)
THEN
    RESPONSE #100
        SetGlobal("G-doomvsfatevsKEY","GLOBAL",10)
		SetGlobal("G-ulfbrandlostambush","GLOBAL",1)
		DisplayString(Player1, @100196)
		PlaySound("NAM157")
        ActionOverride("g-bb017",StartDialogNoSet("g-bbd017"))
        SetGlobal("g-trapvictoryloop","GLOBAL",1)
		Continue()
END