IF
	Global("G-FWRAID","GLOBAL",1)
	Global("G-theaterraided","GLOBAL",0)
THEN
	RESPONSE #100
		CutSceneId(Player1)
		StartCutSceneMode()
		StartCombatCounter()
		SetGlobal("G-theaterraided","GLOBAL",1)
		ActionOverride("g-bb053",DestroySelf())
		ActionOverride("g-bb017",DestroySelf())
		ActionOverride("g-bb017",DestroySelf())
		//ActionOverride("g-bb060",DestroySelf())
		ActionOverride("g-bb066",DestroySelf())
		Wait(2)
		CreateCreature("g-bb201",[839.421],S)  // Ulfbrand Völgarrson Baunaætari
		ActionOverride("g-bb201",ChangeEnemyAlly(Myself,NEUTRAL))
		CreateCreature("g-bb200",[903.407],SE) // Bërserker
		CreateCreature("g-bb200",[804.352],S) // Bërserker
		CreateCreature("g-bb200",[523.651],NE) // Bërserker
		CreateCreature("g-bb200",[483.570],E) // Bërserker
		CreateCreature("g-bb200",[490.397],SW) // Bërserker
		CreateCreature("g-bb200",[904.354],SW) // Bërserker
		CreateCreature("g-bb200",[767.488],S) // Bërserker
		CreateCreature("g-bb200",[685.394],SSW) // Bërserker
		CreateCreature("g-bb200",[737.531],SSW) // Bërserker
		CreateCreature("g-bb200",[989.428],W) // Bërserker
			
		ActionOverride("g-bb200",ChangeEnemyAlly(Myself,NEUTRAL))
		Wait(2)
		CreateCreature("g-bb017",[1018.735],NW)  // Haer'dalis
		CreateCreature("g-bb054",[963.748],NW)  // Raelis Shai
		//CreateCreature("g-bb060",[1164.741],NW)  // Valen Shadowbreath
		//CreateCreature("g-bb141",[917.850],NW)  // Vorrak Dismantle
		//CreateCreature("g-bb142",[1032.908],NW)  // Clausius
		Wait(1)
		CreateCreature("g-bb203",[1161.718],NW) // Strażnik Zagłady
		CreateCreature("g-bb203",[1104.731],NW)  // Strażnik Zagłady
		CreateCreature("g-bb203",[1061.742],NW)  // Strażnik Zagłady
		CreateCreature("g-bb203",[1001.763],NW)  // Strażnik Zagłady
		CreateCreature("g-bb203",[908.818],NW)  // Strażnik Zagłady
		CreateCreature("g-bb203",[971.816],NW)  // Strażnik Zagłady
		CreateCreature("g-bb203",[987.783],NW)  // Strażnik Zagłady

		ActionOverride("g-bb203",ChangeEnemyAlly(Myself,NEUTRAL))
		Wait(2)
		EndCutSceneMode()
		CreateCreature("g-bb190",[839.421],S)  // Nalot Przeznaczonych
		ActionOverride("G-bb190",StartDialogueNoSet("G-bbd190"))
		Continue()
END

