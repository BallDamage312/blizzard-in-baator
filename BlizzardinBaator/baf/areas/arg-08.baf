IF
	True()
THEN
	RESPONSE #100
		SetWorldmap("G-DITCH")
		Continue()
END

IF

Global("g-battlescreenhide","GLOBAL",1)

THEN
    RESPONSE #100
		SetRenderable(Player1,TRUE)
        ActionOverride(Player2,SetRenderable(Player2,TRUE))
        ActionOverride(Player3,SetRenderable(Player3,TRUE))
        ActionOverride(Player4,SetRenderable(Player4,TRUE))
        ActionOverride(Player5,SetRenderable(Player5,TRUE))
        ActionOverride(Player6,SetRenderable(Player6,TRUE))
		SetGlobal("g-battlescreenhide","GLOBAL",0)
END

IF
	GlobalGT("G-doomvsfate","GLOBAL",0)
	Global("G-theaterNPC","GLOBAL",0)
THEN
	RESPONSE #100
		CreateCreature("g-bb017",[849.660],SW)  // Haer'dalis
		CreateCreature("g-bb054",[1028.771],SE)  // Raelis Shai
		//CreateCreature("g-bb060",[552.393],S)  // Valen Shadowbreath
		CreateCreature("g-bb141",[956.861],SW)  // Vorrak Dismantle
		CreateCreature("g-bb142",[1214.818],SSW)  // Clausius
		SetGlobal("G-theaterNPC","GLOBAL",1)
		Continue()
END

IF

	Global("G-theaterabandoned","GLOBAL",1)
THEN
	RESPONSE #100
		ActionOverride("g-bb017",DestroySelf())
		ActionOverride("g-bb054",DestroySelf())
		//ActionOverride("g-bb060",DestroySelf())
		ActionOverride("g-bb141",DestroySelf())
		ActionOverride("g-bb142",DestroySelf())
		SetGlobal("G-theaterabandoned","GLOBAL",2)
		Continue()
END

