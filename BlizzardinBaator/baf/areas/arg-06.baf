IF
    //Global("G-bbmain","GLOBAL",2) // occasion
	InParty("Vhail")
	!StateCheck("Vhail",CD_STATE_NOTVALID)
	Global("G-fakevhadial001triggered","GLOBAL",0) // one time trigger
THEN
    RESPONSE #100
    SetGlobal("G-fakevhadial001triggered","GLOBAL",1) // one time trigger
	SetGlobal("g-fakevhadialogue","GLOBAL",1) // fake dialog selection
	CreateCreatureObject("g-bbvha",Player1,0,0,0) // fake vha creation
	ActionOverride("g-bbvha",StartDialog("g-bbdvha",Player1)) // Fakevha dialogue initiation
END