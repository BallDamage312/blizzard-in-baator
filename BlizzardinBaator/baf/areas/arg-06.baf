IF
    Global("G-Szczurwidolek","GLOBAL",0)
THEN
    RESPONSE #100
        SetDoorLocked("G-door1",TRUE)
		//OpenDoor("G-door1")		
        TriggerActivation("G-doorinfo",TRUE)
		TriggerActivation("G-doortalk",FALSE)
		TriggerActivation("G-To01",FALSE)
		TriggerActivation("G-Toe5",FALSE)
		SetGlobal("G-Szczurwidolek","GLOBAL",1)
END

