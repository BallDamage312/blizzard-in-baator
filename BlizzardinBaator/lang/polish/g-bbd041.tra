@100=~Diabelstwo posyła ci nerwowy uśmiech. "Komu? Ach. Temu... półorkowi spod zepsutego zegara? A cóż ja mu robię?"~
@102=~"Obrabiasz go?"~
@103=~"Słuchaj, siepaczu. Jasne jest, że polujesz tutaj na jelenie. Adam to mój kolega. Nie jest jeleniem. Rozumiemy się?"~
@104=~"Vhailorze, oto złodziej. Złodzieju, poznaj sprawiedliwość."~
@106=~"A masz na to jakiś dowód? Czy ślepo ufasz jego zielonawej szczekaczce?"~
@108=~"Nie mam dowodów, ale jeszcze cię dopadnę."~
@109=~"Słuchaj, siepaczu. Jasne jest, że polujesz tutaj na jelenie. Adam to mój kolega. Nie jest jeleniem. Rozumiemy się?"~
