@0=~"Brązowe papierowe paczki! Materiały pakujące. Papierowe produkty! Zapakujcie się ze mną!"~
@3=~"Brązowe papierowe paczki! Materiały pakujące. Papierowe produkty! Zapakujcie się ze mną!"~
@5=~"Czy znasz githa o imieniu Ikss'odes? Ponoć mieszka gdzieś w pobliżu."~
@7=~"Ten dziwny gith?" Kupiec wskazuje budynki na prawo od chronometru. "Ma leże w tym budynku, o tam, ale dawno go nie widziałem. Mare może wiedzieć więcej. Przyjaźni się z nim."~
@9=~"W porządku. Gdzie mogę ją znaleźć?"~
@12=~"Zwykle przy Pionowym Morzu."~
@14=~"Gdzie jest to Pionowe Morze?"~
@15=~"Dziękuję. Muszę iść. Żegnaj"~
@17=~"W głębi zabudowań, z dala od wody, za pomnikiem Ateny."~
@19=~"Dziękuję. Muszę iść. Żegnaj."~