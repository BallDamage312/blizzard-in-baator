@20284 = ~Rezerwacja~
@20285 = ~Rezerwacja~
@20286 = ~Rezerwacja~
@20287 = ~Rezerwacja~
@20288 = ~Podążaj ścieżką swojej nowej królowej, Kiaransalee, Mściwej Banshee~
@20289 = ~Zostałem przyjęty do kultu Kiaransalee, wspaniałego bóstwa nieumarłych. Moim mentorem podczas nawrócenia był Narthuul Pusta Szczęka, glabrezu oszpecony przez nemezis naszej Pani. Mój cel? Szerzenie śmierci i chaosu. W przyszłości czeka mnie próba. Powinienem się do niej przygotować...~
@20290 = ~Rezerwacja~
@20291 = ~Rezerwacja~
@20292 = ~Rezerwacja~
@20293 = ~Zdobądź komplet kościanych kolczyków i zwróć je Ulfbrandowi w Ysgardzie~
@20294 = ~Ulfbrand podarował mi swój kolczyk w zamian za obietnicę, że odszukam drugi do pary i zwrócę mu je oba po powrocie z Canii. Jeśli tego nie zrobię, spadnie na mnie gniew Wydziału Windykacji. Nie wiem, czy będę miał jeszcze okazję wrócić do Ysgardu, gdzie czeka na mnie Ulfbrand, ale brakujący kolczyk powinien znajdować się gdzieś blisko po drugiej stronie portalu, więc równie dobrze mogę zabrać go ze sobą.~
@20295 = ~Znalazłem zagubiony kolczyk. Miałem rację, zakładając, że znajdę go przy ciele jednego ze szczurołaczych złodziei. Wciąż nie wiem, czy będę miał jeszcze okazję wrócić do Ysgardu, gdzie czeka na mnie Ulfbrand, ale zdobyłem poszukiwany przez niego komplet kolczyków, więc, jeśli się uda, mogę je zwrócić. ~
@20296 = ~XXX~
@20298 = ~Pabeszc potrzebuje odłamka zaginionego golema Lotara, aby naprawić urządzenie niezbędne mu do badań nad szlamami. Golem znajduje się ponoć gdzieś koło Noża w Rzece. Aby tam dopłynąć, potrzebuję łódkę z dobrym nawigatorem. Przewoźnik z plaży i jego monodron pewnie byliby w stanie mi pomóc. ~
@20299 = ~Odnalazłem Nóż w Rzece, ale pod wodą nie ma ani śladu żadnego golema. Gadatliwy szczur zdradził mi, że z wystającej z ziemi rury wylatuje czasami szalony czarodziej. Być może ma on coś wspólnego z zaginięciem golema. Niestety rura jest praktycznie pionowa. Potrzebuję jakiejś solidnej liny, aby dostać się do środka.~
@20299 = ~Odnalazłem Nóż w Rzece, ale pod wodą nie ma ani śladu żadnego golema. Gadatliwy szczur zdradził mi, że z wystającej z ziemi rury wylatuje czasami szalony czarodziej. Być może ma on coś wspólnego z zaginięciem golema. Niestety rura jest praktycznie pionowa. Potrzebuję jakiejś solidnej liny, aby dostać się do środka.~
@20300 = ~Zdobyłem linę do wiązania węży. Podobno jest bardzo wytrzymała. Mogę jej użyć, aby dostać się do rury przy Nożu w Rzece i odszukać zaginionego golema dla Pabeszca.~
@20301 = ~Znalazłem golema. Był ukryty w pewnym laboratorium pełnym pułapek. Gospodarza nie ma w domu. Mogę teraz spróbować zdobyć kawałek ciała golema i dostarczyć go Pabeszczowi. ~
@20302 = ~Udało mi się zdobyć fragment golema Lotara. Muszę go teraz dostarczyć do Kaskady Samobójców, aby Pabeszc mógł naprawić swoje magiczne urządzenie.~
@20303 = ~Udało mi się zdobyć fragment golema Lotara. Muszę go teraz dostarczyć do Kaskady Samobójców, aby Pabeszc mógł naprawić swoje magiczne urządzenie. Uwolniłem też golema z niewoli. Zapewne wróci teraz do Kości Nocy. ~
@20304 = ~Odnajdź smak prawdziwej sztuki~
@20305 = ~Zostawiłem głowę Haer'Dalisa u Elvry w "Wioślarzu Styksu". Wyśle on ją do swojego przyjaciela, znanego mistrza przetworów. Wyobrażam sobie, że głowa wróci do mnie w pysznej postaci. Powinienem odszukać Elvrę po powrocie z Piekieł.~
@20306 = ~Rezerwacja~
@20307 = ~Rezerwacja~
@20308 = ~Rezerwacja~
@20309 = ~Rezerwacja~