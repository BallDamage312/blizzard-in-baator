@300306 = ~Kanał - pod Kładką Zaddfuma~
@300307 = ~Kanał - Pionowe Morze~
@300308 = ~Teatr dramatyczny "Podmaszcze"~
@300309 = ~Kanał - Kaskada Samobójców~
@300310 = ~Rezydencja Kabatuma~
@300311 = ~Świątynia szczurzego boga~
@300312 = ~"Wioślarz Styksu" - taras~
@300313 = ~Opuszczony dom~
@300314 = ~"Szczurwidołek" (zniszczony)~
@300315 = ~Biblioteka~
@300316 = ~Ulice Sigil~
