@100000 = ~"Giń!"~
@100001 = ~"Zamrożę ci dupsko!"~
@100002 = ~"Oto wchodzi Haer'Dalis!"~
@100003 = ~"Przeznaczenie daje nam wszystkim znak."~
@100004 = ~"Oto rola, którą rad jestem zagrać!"~
@100005 = ~"Taaak, krew miasta. W każdej sferze płynie i krąży tak samo."~
@100006 = ~*Gwiżdże*~
@100007 = ~"Z chęcią zatańczę do twojej melodii... jeśli jeno nauczysz się grać."~
@100008 = ~"Ależ cieplutko. Czyż nie?"~
@100009 = ~"Co za wspaniałe miejsce!"~
@100010 = ~"Ach!"~
@100011 = ~"Nie wiesz nic o Sztuce!"~
@100012 = ~"Teraz umrzesz."~
@100013 = ~"Skończ to!"~
@100014 = ~"Giń, kurduplu!"~
@100015 = ~"MÓJ WILK!!!"~
@100016 = ~"Ukorz się!"~
@100017 = ~"Ech. No tak..."~
@100018 = ~"Czarny Ziutku... Jak by to... Przyszedłem skonfiskować... twojego chochlika."~
@100019 = ~"Tak... mi się zdaje."~
@100020 = ~"Czyżby?"~
@100021 = ~"Zdaje mi się, że nie."~
@100022 = ~"Joooouż się robi."~
@100023 = ~"W porzoooooądku..."~
@100024 = ~"Rooooutterkiński Rooooum!"~
@100025 = ~"Kanałowy Koooouktajl ma być?"~
@100026 = ~*Rechot*~
@100027 = ~"Plaża w Kanale, plaża w Kanale. Tylko u mnie, zaraz wyruszam!"~
@100028 = ~"Chodźcie, chodźcie. Wygrzejcie kości w najcieplejszym miejscu w całym Ulu!"~
@100029 = ~"Wycieczka do Kanału! Tylko 10 miedziaków za wstęp!"~
@100030 = ~"Łooo..."~
@100031 = ~"Sprowadź pomyślne nurty dla naszych pobratymców..."~
@100032 = ~"Sprowadź śmierć na naszych wrogów!"~
@100033 = ~"Rach-ciach, tak-tak... Flaki chlap-ciap!"~
@100034 = ~"Chwała Istishii!"~
@100035 = ~"Chwała Baluu!"~
@100036 = ~"Chwała Zmarłej Pani!"~
@100037 = ~"Chwała Panu Szramie!"~
@100038 = ~*Wycie*~
@100039 = ~"Skurlała jaszczurko!"~
@100040 = ~"Tym razem przegrasz z kretesem!"~
@100041 = ~"Co, abiszaju, Tiamat poskąpiła czerwonego barwnika?"~
@100042 = ~"Grrr..."~
@100043 = ~"Nawet poprawnie oszukiwać nie umiesz!"~
@100044 = ~"Oż ty pchlarzu! Odszczekaj to!"~
@100045 = ~"Pewnego dnia zaśpiewam 'Radosne płomienie' na twoim grobie."~
@100046 = ~*Westchnięcie*~
@100047 = ~"Śmiałku, chcesz się zabawić?"~
@100048 = ~"Porozmawiajmy, przystojniaku..."~
@100049 = ~"Słuchaj uważnie, bo nie będę dwa razy powtarzać..."~
@100050 = ~"Rozumiesz, o czym mówię?"~
@100051 = ~"Paradoks strzały, już ci to tłumaczyłem..."~
@100052 = ~"Czej, myślę, że już łapię..."~
@100053 = ~"Stary, chyba jednak nie do końca rozumiem..."~
@100054 = ~"Aha..."~
@100055 = ~*Czknięcie*~
@100056 = ~"Czegoś poszszeba...?"~
@100057 = ~"Kierowniku! Kieeerownikuuu!"~
@100058 = ~"Op... oprowadzacz! Najlepszy w tym mrowisku!"~
@100059 = ~"Da kierownik drobne, ja pooprowadzam!"~
@100060 = ~*Beknięcie*~
@100061 = ~"Aaale to powaszszne oskaarżenie...!"~
@100062 = ~"Och, Sonne."~
@100063 = ~"Naprawdę mnie kochasz?"~
@100064 = ~"Kochanie, proszę, bądź ze mną szczera."~
@100065 = ~"Czy ty mnie już mnie nie kochasz?"~
@100066 = ~"Och, Zacku..."~
@100067 = ~"Wiesz, że cię kocham."~
@100068 = ~"Dlaczego mnie nie rozumiesz?"~
@100069 = ~"Miłość nie jest tym, czym ci się zdaje."~
@100070 = ~"Zamawiasz coś? A może interesuje cię odrobina hazardu?"~
@100071 = ~"Piwo raz!"~
@100072 = ~"Piwo dla ciebie, trepie!"~
@100073 = ~"Trzymaj!"~
@100074 = ~"Świeży browar dla ciebie!"~
@100075 = ~"Uwaga, napitki w drodze!"~
@100076 = ~"Kto zamawiał pszeniczne?"~
@100077 = ~"Otchłanne Ale Avnera!"~
@100078 = ~"Krwawe Wino Baatezu!"~
@100079 = ~"Wyniki wyścigów czaszkoszczurów..."~
@100080 = ~"Nie bić się tam!"~
@100081 = ~"Żadnego otwartego ognia w lokalu! To nie 'Gorejący'!"~
@100082 = ~"Jakieś wieści z frontu?"~
@100083 = ~"Szlamy! Gdzie jesteście?"~
@100084 = ~"Jeden... Dwa..."~
@100085 = ~"Zaraz, czy to jest pojedynczy szlam? A może dwa bardzo blisko siebie?"~
@100086 = ~"Na Primusa, jak tu brudno..."~
@100087 = ~"Cassie? To ty?"~
@100088 = ~"Grrr!"~
@100089 = ~"Ekhm. No ryczę przecież."~
@100090 = ~"Bój się!"~
@100091 = ~*Mamrocze*~
@100092 = ~*Mruczy pod nosem*~
@100093 = ~"Sześć... siedem... Cholera, znowu się pomyliłem..."~
@100094 = ~"Pory... Przeklęte pory..."~
@100095 = ~"Nie! Nie! NIE!!!"~
@100096 = ~"Zgiń, przepadnij!"~
@100097 = ~"Już nigdy mnie nie skrzywdzisz!"~
@100098 = ~*Krzyk*~
@100099 = ~*Westchnięcie*~
@100100 = ~*Ciężkie westchnięcie*~
@100101 = ~"Hi, hi!"~
@100102 = ~*Rechot*~
@100103 = ~*Chichot*~
@100104 = ~"Szczurki! Chodźcie do mnie, szczureczki!"~
@100105 = ~"Mam cię!"~
@100106 = ~"Nie! Nie uciekaj!"~
@100107 = ~"Złoto!"~
@100108 = ~"Złoooootooo!"~
@100109 = ~"Nie ma złota...?"~
@100110 = ~"Obserwują mnie!"~
@100111 = ~"Oni mnie widzą!"~
@100112 = ~"Czuję twój wzrok! Nie widzę, ale czuję!"~
@100113 = ~"Oczy... Widzę oczy! W mojej głowie!"~
@100114 = ~*Kap*~
@100115 = ~"Oświecenie już tak blisko..."~
@100116 = ~"Razu pewnego człowiek w Ulu..."~
@100117 = ~"Jaki powinien być następny wers...?"~
@100118 = ~"W Ulu... Co się rymuje z 'Ulu'...?"~
@100119 = ~"Czy tam w ogóle jest siedem sylab?"~
@100120 = ~"Dobra, to chyba zabrzmi lepiej..."~
@100121 = ~*Chrząknięcie*~
@100122 = ~"Dobra, od początku..."~
@100123 = ~"Przepraszam..."~
@100124 = ~"Widzieliście może dziewczynę w czerwonej sukience?"~
@100125 = ~"Nie patrzcie się tak na mnie..."~
@100126 = ~"Piwo raz!"~
@100127 = ~"Piwo dla ciebie!"~
@100128 = ~"Zamawiasz coś, dwunogu?"~
@100129 = ~"Trzymaj!"~
@100130 = ~"Świeży browar dla ciebie!"~
@100131 = ~"Uwaga, napitki w drodze!"~
@100132 = ~"Kto zamawiał piwo z pestkami słonecznika?"~
@100133 = ~"Piwo kukurydziane raz!"~
@100134 = ~"Jaka dziś śpiewka? Pij i opowiadaj."~
@100135 = ~"Cholerni ryboludzie! Znowu zaatakowali naszych?"~
@100136 = ~"Szpieg w Ziemiach Umarłych? Obawiam się, że go zdybali."~
@100137 = ~"Obczaj tego bystrzaka."~
@100138 = ~"O co w ogóle chodzi z tym szkieletem? Mam nadzieję, że ten szarobrody to nie od Hargrimma."~
@100139 = ~"Zaczekaj jeszcze chwilę. Podejdę do ciebie."~
@100140 = ~"Bardzo boli?"~
@100141 = ~"Zaraz poczujesz się lepiej."~
@100142 = ~"Spokojnie! Już ja temu zaradzę."~
@100143 = ~"Bólu, odejdź!"~
@100144 = ~"Kim ja jestem...?"~
@100145 = ~"Ej, ty! Znasz mnie może?"~
@100146 = ~"Kim byłem całe życie?!"~
@100147 = ~"Jestem tylko... diabelstwem?"~
@100148 = ~"To Sigil, prawda?"~
@100149 = ~"Panie! Poratuj pan brzdękiem!"~
@100150 = ~"Potrzebuję kamieni..."~
@100151 = ~"Masz kamienie?"~
@100152 = ~"Potrzebuję więcej..."~
@100153 = ~"Patrzcie na te kolory!"~
@100154 = ~"Mamo!"~
@100155 = ~*Krzyk*~
@100156 = ~"Dwunogi w świątyni!"~
@100157 = ~"Poleje się krew!"~
@100158 = ~"Squerriku! Przyjmij te skarby i krwawą ofiarę na twoją chwałę!"~
@100159 = ~"Śmierć dwunogom!"~
@100160 = ~"Szanowny panie! Skoro już tu pan jest, to nie zaszkodzi mały podpisik przed skokiem."~
@100161 = ~"Szybki podpisik, hop i złota przyszłość w krainie aniołów!"~
@100162 = ~"Zdecydował się pan?"~
@100163 = ~"Rozumiem, rozumiem. To trudna decyzja. Będę tutaj czekać."~
@100164 = ~"Niedobrze. Zaborcy już tu węszą..."~
@100165 = ~"Szefie, obawiam się, że nie ma czasu na kółko teatralne. Trzeba nam się gotować do bitki."~
@100166 = ~"Wuff!"~
@100167 = ~"Auuu!"~
@100168 = ~"Jakieś wieści z Sigil?"~
@100169 = ~"Jedzcie do syta! Jutro walczymy po raz kolejny!"~
@100170 = ~"Podajcie mi dziczyznę."~
@100171 = ~"Przeznaczeni! Przeznaczeni! Co czyni prawo? Siła!"~
@100172 = ~"Przygotujcie łaźnię i saunę, niedługo się tam wybieram."~
@100173 = ~"Heill Óðinn! Sæl Óðinn!"~
@100174 = ~*Siorb*~
@100175 = ~*Siooorb*~
@100176 = ~*WURR TURR*~
@100177 = ~"Nie mogę się doczekać jutrzejszej bitwy."~
@100178 = ~"Co za uczta!"~
@100179 = ~"Siła czyni prawo!"~
@100180 = ~"Siła! Siła! Siła!"~
@100181 = ~"Heill Óðinn!"~
@100182 = ~"Dobijemy targu?"~
@100183 = ~"Nie obchodzi mnie, kim jesteś. Liczy się tylko handel, śmiałku."~
@100184 = ~Skrzynia została prawdopodobnie zamknięta za pomocą magii. Obok uchwytu wyrzeźbiony jest wizerunek klucza, ale jego szczegóły są niewyraźne.~
@100185 = ~Skrzynia została otwarta dzięki wspomnieniu z wizerunkiem klucza z książki-mimika.~
@100186 = ~"CHRUPKI KRABOWE! CHRUPKI KRABOWE! OLEJ GODZINY NADLICZBOWE, KUP CHRUPKI KRABOWE!"~
@100187 = ~"CHRUPKI KRABOWE! CHRUPKI KRABOWE! PO CO WAM LODY MALINOWE, JAK MACIE CHRUPKI KRABOWE?"~
@100188 = ~"CHRUPKA PAKUJ DO DZIÓBKA! HOP HOP!"~
@100189 = ~"KTO NIE JE CHRUPKA, TEN PARÓWKA! HYC HYC!" ~
@100190 = ~"Uff..."~
@100191 = ~"Dabus, hyc, do rozbierania."~
@100192 = ~*KLASK KLASK*~
@100193 = ~"Czy nadal jestem tym, kim jestem w moich snach?"~
@100194 = ~"Jak mogę odróżnić płomień od iskry?"~
@100195 = ~"Interesujące..."~
@100196 = ~^0xffFFFFFFNowy wpis w dzienniku^-~
@100197 = ~"ŚMIERĆ!"~
@100198 = ~"Niewierni zostaną ukarani. Czeka ich ŚMIERĆ!"~
@100199 = ~"Þetta var frábardagi."~
@100200 = ~"Ég held að ég hafi drepið að minnsta kosti tólf."~
@100201 = ~"Það var nánast eins og á fornum dögum."~
@100202 = ~"Það er leitt með fallna menn."~
@100203 = ~"Gaaaa!"~
@100204 = ~"Ojojoooj!!!"~
@100205 = ~"Ratunku!!!"~
@100206 = ~"Maaamooo!!!"~
@100207 = ~"Aaaaa!!!"~
@100208 = ~^0xffFFFFFFNowy wpis w dzienniku^-~
@100209 = ~"To musi być gdzieś tutaj..."~
@100210 = ~"Czy to było na tym poziomie?"~
@100211 = ~"Moje miasto mnie potrzebuje!"~
@100212 = ~"A może by..."~
@100213 = ~"Pięknie..."~
@100214 = ~*Niuch niuch*~
@100215 = ~"Róże, róże!"~
@100216 = ~"Kupujcie kwiaty!"~
@100217 = ~"Krople deszczu na różach!"~
@100218 = ~"Wąsiki kociąt!"~
@100219 = ~"Koty, urocze koty."~
@100220 = ~"Zawsze chciałeś mieć przyjaciela, który cię zje?"~
@100221 = ~"Lśniące miedziane czajniki!"~
@100222 = ~"Wyposaż u mnie swoją kuchnię!"~
@100223 = ~"Garnki i czajniki!"~
@100224 = ~"Ciepłe wełniane rękawiczki!"~
@100225 = ~"Przewiewne, luźne koszule."~
@100226 = ~"Ubrania na każdą pogodę!"~
@100227 = ~"Brązowe papierowe paczki!"~
@100228 = ~"Pudełka! Tylko u mnie!"~
@100229 = ~"Wszystko z papieru!"~
@100230 = ~"SZNUUURKI!"~
@100231 = ~"Zara odpływam. Ostatnie miejsce!"~
@100232 = ~"Na moim promie poczujesz się jak wilk morski."~
@100233 = ~"Ul-Kanał, Kanał-Ul, codziennie, przez cały dzień!"~
@100234 = ~"Wracacie do 'Gorejącego'?"~
@100235 = ~"Hej! Tutaj! Poprowadzę was do centrum Ula."~
@100236 = ~"Halo, halo!"~
@100237 = ~Dwie części jadeitowej czaszki natychmiast przyciągają się do siebie i łączą się w całość, wytwarzając zieloną iskrę energii.~
@100238 = ~"O potężny Istishio, przyjmij naszą ofiarę, by krwi twój ocean szerzył się wnet. Tak-tak!"~
@100239 = ~"Nie! Litości, błagam!"~
@100240 = ~"Blup, dup, ciup. Rach-ciach."~
@100241 = ~"Chwała, chwała Istishii."~
@100242 = ~"To co teraz robimy?"~
@100243 = ~"Wiem! Wkradnijmy się do Więzienia!"~
@100244 = ~"A może by ukraść jakiś klucz Artusowi?"~
@100245 = ~"Nuda."~
@100246 = ~"Ciekawe, co jest za krawędzią..."~
@100247 = ~"Łeeeeee!"~
@100248 = ~*Chlip*~
@100249 = ~"Łaaaaaa!"~
@100250 = ~^0x008000"Panie, zatrzymaj się. Coś jest nie tak... Prod zaraz..."^-~
@100251 = ~"E! To ten, co ubił szefa. Kaowiec, cho no tu!"~
@100253 = ~"Wspaniały teatr, nieprawdaż?"~
@100256 = ~"Nie mam nic przeciwko komedii, ale niech te żarty czemuś służą."~
@100257 = ~"Nie, nie wydaje mi się, żeby łamanie czwartej ściany w tym miejscu było uzasadnione..."~
@100258 = ~"W porządku, to nawet całkiem ciekawe..."~
@100262 = ~"Przećwiczmy to jeszcze raz, dobra?"~
@100263 = ~"Jeszcze raz."~
@100264 = ~"Mam nadzieję, że Kirinaldo czuje się lepiej."~
@100265 = ~"Gdzie ten dubler? Znów się spóźnia."~
@100266 = ~"Sigilijska Trupa zasłuży na waszą uwagę i miedź, obiecuję!"~
@100267 = ~"Jeśli dobrze nam pójdzie, trasa po Pierwszej sfinansuje się sama."~

