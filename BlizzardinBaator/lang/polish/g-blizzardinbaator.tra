@200000 = ~"Wiemy już, co nam ciemność odkrywa,"~ [wers1]
@200001 = ~"Czy głęboki, czy płytki nasz grób;"~ [wers2]
@200002 = ~"Starzy nasi ojcowie, kochanki,"~ [wers3]
@200003 = ~"Czuć będziemy, czy zmógł sen ich już."~ [wers4]
@200004 = ~"Zobaczymy, czy piekło jest niebem,"~ [wers5]
@200005 = ~"Czy chleba nie da nam chwast,"~ [wers6]
@200006 = ~"Siedemdziesiąt radości po siedem,"~ [wers7]
