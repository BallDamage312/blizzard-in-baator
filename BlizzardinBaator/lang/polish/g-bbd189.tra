@118=~Zerknij na Vhailora. Mógłby skupić na sobie wielu wrogów, dając czas na działanie mniej wytrzymałym sojusznikom.~
@119=~Zerknij na Ignusa. Jego obecność wprowadzi chaos, zarówno wśród wrogów, jak i sojuszników.~
@120=~Nie ma już czasu. Jesteście prawie na miejscu.~
@122=~Nordom nie rozumie potrzeby zachowania dyskrecji. Brzęczy i stukocze.~
@123=~"Nowa dyrektywa dla Nordoma? Oczekuję potwierdzenia." ~ [MODRO01]
@125=~"Tak, Nordomie. Trzymaj się z dala od kłopotów. Najlepiej gdzieś wysoko."~
@127=~Nordom podskakuje w miejscu.~
@128=~"Potwierdzam." Zbuntowany modron nie wydaje się mieć żadnych dodatkowych uwag ani wątpliwości. ~ [NOR089]
@129=~Odwracasz wzrok od Nordoma i spoglądasz przed siebie, by ocenić, jak daleko jeszcze.~
@131=~Jesteś sam. Twoi tymczasowi sojusznicy czekają już tam, skąd wydobywają się kłęby dymu. Już czas.~
@132=~Zerknij na Dak'kona - wojownika, którego zmysł strategiczny i opanowanie mogą zmienić bieg potyczki.~
@133=~Zerknij na Mortego. Był z tobą od samego początku. Jest szybki i może dostać się w trudno dostępne miejsca. Byłby kluczowy przy atakowaniu z zaskoczenia.~
@134=~Zerknij na Annę. Całe życie spędziła wśród cieni. To one są jej domeną. Mogłaby je wykorzystać, by dosięgnąć wrogów, gdy będą najbardziej wrażliwi na atak.~
