@0=~Kapłan odwraca się od ołtarza i wreszcie cię zauważa. Nie wydaje się zdumiony twoją obecnością, lecz raczej rozradowany. Wita cię szerokim, rybim uśmiechem. "Łoooo... Kolejna ofiara? tak-tak! Czy też nowy wyznawca wszechmocnego pana Istishii? Jedno i drugie sprawia Dopilpowi radość!"~
@2=~"Witaj... Wyznawca? Nie. Jeszcze nie. Powiedz mi więcej o Istishii." ~
@3=~Kłamstwo: "Oczywiście. Chwała Istishii! Przypomnij mi, bracie, jak najlepiej złożyć hołd naszemu panu."~
@4=~"Nie wyznaję Istishii i nie zamierzam zacząć. Mów natychmiast, co tutaj robicie z tymi nieszczęśnikami!"~
@5=~"Witaj... Wyznawca? Nie. Jeszcze nie. Powiedz mi więcej o Istishii." ~
@6=~Kłamstwo: "Oczywiście. Chwała Istishii! Przypomnij mi, bracie, jak najlepiej złożyć hołd naszemu panu."~
@7=~"Nie wyznaję Istishii i nie zamierzam zacząć. Mów natychmiast, co tutaj robicie z tymi nieszczęśnikami!"~
@8=~"Nie interesuje mnie, co tutaj robicie. Myślę, że po prostu was pozabijam."~
@9=~"Potwory! Przybyłem zakończyć wasze krwawe rytuały!"~
@10=~"Nie jestem wyznawcą, jestem waszą zgubą. Wysłały mnie szczurołaki, abym ukrócił wasze krwawe zapędy."~
@11=~"Nie jestem wyznawcą. Wysłały mnie szczurołaki, abym was usunął, ale mam zamiar rozwiązać to pokojowo."~
@14=~Kapłan odwraca się do zgromadzenia. "Łooo... Wracasz, tak-tak! Nowy wyznawca wszechmocnego pana Istishii!"~
@16=~"Nie interesuje mnie, co tutaj robicie. Myślę, że po prostu was pozabijam."~
@17=~"Potwory! Przybyłem zakończyć wasze krwawe rytuały!"~
@18=~"Nie jestem wyznawcą, jestem waszą zgubą. Wysłały mnie szczurołaki, abym ukrócił wasze krwawe zapędy."~
@19=~"Nie jestem wyznawcą. Wysłały mnie szczurołaki, abym was usunął, ale mam zamiar rozwiązać to pokojowo."~
@20=~"Eee... Chyba trochę się zgubiłem. Nie przeszkadzajcie sobie. Żegnam." ~
@22=~"Ach, tak-tak, jakiś ty silny i potężny! Potężniejszy od Istishii! Najpotężniejszy z mocy! Oszczędź nas, Panie Szramo, a będziemy ci wiernie służyć!"~
@24=~"Hmm, zgoda. Znajcie moją łaskę. Oszczędzę was."~
@25=~"Nie, raczej nie. Gińcie."~
@26=~"Orville wyraził się jasno. Śmierć Dopilpowi."~
@28=~"Co teraz, co teraz, Panie Szramo?" Dopytuje Dopilp, składając ci lekki pokłon.~
@30=~"Mam dla was nowe przykazania."~
@31=~"W tej chwili nie mam dla was żadnych poleceń. Idźcie i czyńcie moją wolę."~
@32=~"Wcale nie mam ochoty być bogiem. Radźcie sobie sami."~
@34=~Dopilp z ekscytacją obserwuje, jak pobliscy kuo-toa przenoszą różne rzeczy. Widzi, jak się zbliżasz, i wyraźnie rozważa ukłon, ale ostatecznie decyduje się na głębsze skinienie głową. "Pan Szrama! Zostawiłeś nas w dobrych rękach. Pan Baluu i Kilthas są dla nas dobrzy, tak-tak!"~
@36=~"Dobrzy dla was?"~
@37=~"Cieszę się, Dopilpie. Bywaj."~
@39=~"Pan Szrama! Uczymy się tak wiele o Zmarłej Pani. Dzięki-dzięki!"~
@41=~"Co u twojej kongregacji?"~
@42=~"Co u twojej kongregacji?"~
@43=~"Chwała niech będzie Mściwej Królowej. Żegnaj."~
@45=~Dopilp unosi swój hak i wydaje bulgoczący okrzyk bojowy. Pozostali kuo-toa wtórują mu podobnym okrzykiem. "Tak-tak. Śmierć naszym wrogom!" W przeciągu kilkunastu sekund ryboludzie łapią za broń i porozrzucany po piwnicy ekwipunek, a następnie nurkują wprost w gęstą, ciemną wodę. Najwyraźniej znają jakiś sekretny sposób na dostanie się do ukrytej karczmy.~
@47=~"Orville chyba będzie miał gości..."~
@49=~"Łooo, tak-tak, Dopilp wszystko wyjaśni, tak-tak!" Kapłan buja się w ekscytacji na boki, a wierna kongregacja powtarza jego ruchy. "Istishia to wielki pan wody, tak-tak, wielki pan! Ześle nam zdrowia, szczęścia, pomyślności, a jego mokra potęga nigdy nie zagaśnie, tak-tak! Składamy ofiary mięsa i krwi dla wielkiego pana! Rach-ciach, tak-tak, tnie nóż i flaki chlap-ciap!" Pozostali kuo-toa intonują 'chlap-ciap' z radością, jakby nie mogli się już tego doczekać.~
@51=~"To, co robicie, jest niewłaściwe. Natychmiast przestańcie."~
@52=~"Działacie mi tym ciamkaniem na nerwy. Pora na śmierć."~
@53=~"Jest tylko jedno bóstwo, które się liczy. I spluwa na waszego pana wody. Uklęknijcie przed Kiaransalee, marne istoty, albo gińcie."~
@54=~"Chyba już pójdę. Żegnam."~
@56=~Kapłan posyła ci szeroki rybi uśmiech pełen zachwytu, bujając się w ekscytacji na boki. Wierna kongregacja powtarza jego ruchy. "Wyznawca, tak-tak, wyznawca! Dopilp wszystko przypomni! Istishia, wielki pan wody, tak-tak, zsyła nam zdrowia, szczęścia, pomyślności, a jego mokra potęga nigdy nie zagaśnie, tak-tak! Składamy ofiary mięsa i krwi dla wielkiego pana! Rach-ciach, tak-tak, tnie nóż i flaki chlap-ciap!" Pozostali kuo-toa intonują 'chlap-ciap' z radością, jakby nie mogli się już tego doczekać.~
@58=~"To, co robicie, jest niewłaściwe. Natychmiast przestańcie."~
@59=~"Działacie mi tym ciamkaniem na nerwy. Pora na śmierć."~
@60=~"Jest tylko jedno bóstwo, które się liczy. I spluwa na waszego pana wody. Uklęknijcie przed Kiaransalee, marne istoty, albo gińcie."~
@61=~"Chyba już pójdę. Żegnam."~
@63=~Kapłan przekrzywia głowę, jakby nie do końca rozumiał, o czym mówisz. "Z kim? O kogo chodzi? O tamtych, tak-tak?" Wskazuje na biedaków przykutych do kamienia. "Dary dla pana Istishii. Dopilp wszystko wyjaśni! Istishia, wielki pan wody, tak-tak, zsyła nam zdrowia, szczęścia, pomyślności, a jego mokra potęga nigdy nie zagaśnie, tak-tak! Składamy ofiary mięsa i krwi dla wielkiego pana! Rach-ciach, tak-tak, tnie nóż i flaki chlap-ciap!" Pozostali kuo-toa intonują 'chlap-ciap' z radością, jakby nie mogli się już tego doczekać.~
@65=~"To, co robicie, jest niewłaściwe. Natychmiast przestańcie."~
@66=~"Działacie mi tym ciamkaniem na nerwy. Pora na śmierć."~
@67=~"Jest tylko jedno bóstwo, które się liczy. I spluwa na waszego pana wody. Uklęknijcie przed Kiaransalee, marne istoty, albo gińcie."~
@69=~"Łooo, tak-tak, Dopilp wszystko wyjaśni, tak-tak!" Kapłan buja się w ekscytacji na boki, a wierna kongregacja powtarza jego ruchy. "Istishia to wielki pan wody, tak-tak, wielki pan! Ześle nam zdrowia, szczęścia, pomyślności, a jego mokra potęga nigdy nie zagaśnie, tak-tak! Składamy ofiary mięsa i krwi dla wielkiego pana! Rach-ciach, tak-tak, tnie nóż i flaki chlap-ciap!" Pozostali kuo-toa intonują 'chlap-ciap' z radością, jakby nie mogli się już tego doczekać.~
@70=~Patrzysz na kuo-toa, istoty, których wiara potrafi obdarzyć obiekt czci ogromną mocą. Jeśli to ciebie zaczęliby czcić, mógłbyś wiele na tym zyskać. Może mały cud, powiedzmy... zmartwychwstanie, przekonałby ich do nawrócenia?~
@72=~"Rozumiem. Chciałbym uczcić wielkiego Istishię. Złóżcie mu mnie w ofierze na ołtarzu."~
@73=~"To, co robicie, jest niewłaściwe. Natychmiast przestańcie."~
@74=~"Działacie mi tym ciamkaniem na nerwy. Pora na śmierć."~
@75=~"Jest tylko jedno bóstwo, które się liczy. I spluwa na waszego pana wody. Uklęknijcie przed Kiaransalee, marne istoty, albo gińcie."~
@77=~Kapłan posyła ci szeroki rybi uśmiech pełen zachwytu, bujając się w ekscytacji na boki. Wierna kongregacja powtarza jego ruchy. "Wyznawca, tak-tak, wyznawca! Dopilp wszystko przypomni! Istishia, wielki pan wody, tak-tak, zsyła nam zdrowia, szczęścia, pomyślności, a jego mokra potęga nigdy nie zagaśnie, tak-tak! Składamy ofiary mięsa i krwi dla wielkiego pana! Rach-ciach, tak-tak, tnie nóż i flaki chlap-ciap!" Pozostali kuo-toa intonują 'chlap-ciap' z radością, jakby nie mogli się już tego doczekać.~
