@276=~"Prod nigdy nie chciał odejść. Prod został zmuszony. Prod dziękuje ci za ratunek!" ~ [g-00608]
@277=~"Wspaniale." W jednej chwili promień magicznej energii przecina zaśnieżoną ścieżkę i uderza małego chochlika. ~ [g-00713]
@279=~"Prod!"~
@280=~Zaatakuj.~
@282=~Akershus klaszcze. "Naprawdę ci wierzę. Wyglądasz na silnego, samotnego śmiałka." Robi krok do przodu i składa ręce, patrząc na Proda. "W przeciwieństwie do ciebie, mały potworze."~
@283=~"Jesteś nikim, Prod. To twoi przyjaciele abiszaje naprawdę go interesują. Powiedz nam, kto jest twoim nowym panem, a daruję ci życie. Mammon nie wie nawet o twoim istnieniu."~
@284=~Prod potrzebuje na odpowiedź znacznie więcej czasu niż zwykle. Trzykrotnie otwiera i zamyka małe usta, aż w końcu wydaje z siebie dźwięk. "To Levistus", mówi.~
@285=~"Prod nigdy nie chciał odejść. Prod został zmuszony. Prod dziękuje ci za ratunek!" ~ [g-00608]
@286=~"Wspaniale." W jednej chwili promień magicznej energii przecina zaśnieżoną ścieżkę i uderza małego chochlika. ~ [g-00713]
@288=~"Prod!"~
@289=~Zaatakuj.~
@291=~Widzisz oczami wyobraźni sugestię wspomnienia. Obraz koncentrycznych, surowych murów, widzianych z powietrza. Platformy do lądowania, na której osiada twoja machina... ~ [SPTR_01]
@292=~Maszerujące równymi rzędami oddziały podobnie do siebie wyglądających wojowników. Nie. Nie wojowników, żołnierzy. To istotna różnica. Wszyscy tu posiadają rangi. Rangę posiada i ona. ~
@293=~Jest piękna. Lśniąca. Czysta. Jej metaliczną skórę zdobią symetryczne wzory, mające na celu wzbudzać strach w tych, którzy je zobaczą. Zwykle nie lubi obcych w swoim mieście. Ale ty jesteś inny. Rozkazuje ci się położyć. Pamiętasz ukłucia i ból, ale rezultat jest... perfekcyjny.~
@294=~Jest teraz później. Dużo później. W lustrze starasz się dostrzec pamiątkę po metalowej kobiecie z Rigus. Niestety skóra w tym miejscu jest spalona. Nie pamiętasz już, jak wyglądał ten wzór. Pamiętasz tylko... jego perfekcję.~
@296=~Powróć do rzeczywistości.~
@298=~Widzisz, że Akershus patrzy na ciebie zmieszany. "Zrobiło się bardzo cicho, siepaczu. Wszystko w porządku?"~
@300=~"Przepraszam. Cóż on przedstawia?"~
@302=~"Mam jeszcze kilka pytań."~
@303=~"Właściwie to powinienem już iść."~