@0=~"Kocięta! Tylko u mnie. Tylko spójrzcie na ich urocze wąsiki. Po co komu miłość, jak można mieć kota?"~
@3=~"Kocięta! Tylko u mnie. Tylko spójrzcie na ich urocze wąsiki. Po co komu miłość, jak można mieć kota?"~
@5=~"Czy znasz githa o imieniu Ikss'odes? Ponoć mieszka gdzieś w pobliżu."~
@7=~Kupiec wskazuje budynki na prawo od chronometru. "Ten dziwny gith? Ma leże w tym budynku, o tam, ale dawno go nie widziałem. Zapytaj jego przyjaciółkę, Mare."~
@9=~"W porządku. Gdzie mogę ją znaleźć?"~
@11=~"Zwykle przy Pionowym Morzu."~
@13=~"Gdzie jest to Pionowe Morze?"~
@14=~"Dziękuję. Muszę iść. Żegnaj"~
@16=~"W głębi zabudowań, z dala od wody, za pomnikiem Ateny."~
@18=~"Dziękuję. Muszę iść. Żegnaj."~