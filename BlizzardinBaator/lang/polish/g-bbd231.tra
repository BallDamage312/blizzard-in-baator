@0=~"Lśniące miedziane czajniki! I wszystko, czego potrzebujecie w kuchni. Najlepsza jakość w okolicy!"~
@3=~"Lśniące miedziane czajniki! I wszystko, czego potrzebujecie w kuchni. Najlepsza jakość w okolicy!"~
@5=~"Czy znasz githa o imieniu Ikss'odes? Ponoć mieszka gdzieś w pobliżu."~
@7=~Kupiec wskazuje budynki na prawo od chronometru. "Ten dziwny gith? Ma leże w tym budynku, o tam, ale dawno go nie widziałem. Zapytaj jego przyjaciółkę, Mare."~
@9=~"W porządku. Gdzie mogę ją znaleźć?"~
@12=~"Zwykle przy Pionowym Morzu."~
@14=~"Gdzie jest to Pionowe Morze?"~
@15=~"Dziękuję. Muszę iść. Żegnaj"~
@17=~"W głębi zabudowań, z dala od wody, za pomnikiem Ateny."~
@19=~"Dziękuję. Muszę iść. Żegnaj."~