@100000 = ~"Die!"~
@100001 = ~"I'll freeze your ass!"~
@100002 = ~"Enter Haer'Dalis!"~
@100003 = ~"Fate beckons us all."~
@100004 = ~"Tis a role I am glad to play!"~
@100005 = ~"Aye, the lifeblood of a city. *chuckle* It ebbs and flows the same on any plane."~
@100006 = ~*Whistle*~
@100007 = ~"I shall be glad to dance to your tune... if you but learn to play."~
@100008 = ~"So warm. Isn't it?"~
@100009 = ~"What a great place to be!"~
@100010 = ~"Ahh!"~
@100011 = ~"You know nothing of the Art!"~
@100012 = ~"Now, you die."~
@100013 = ~"Finish it!"~
@100014 = ~"Die, you runt!"~
@100015 = ~"MY WOLF!!!"~
@100016 = ~"Be obedient!"~
@100017 = ~"Eh. Right, then..."~
@100018 = ~"Black Joseph... How should I put it... I've come to confiscate... your imp."~
@100019 = ~"Yes... I think so."~
@100020 = ~"Is that so?"~
@100021 = ~"I think not."~
@100022 = ~"Coooaaming right up."~
@100023 = ~"Ooooaaalright..."~
@100024 = ~"Rooooutterkin Rooooum's ooooup!"~
@100025 = ~"Ditch Cooooucktail, right?"~
@100026 = ~*Croak*~
@100027 = ~"Gather round! Trip to the Ditch beach, coming right up!"~
@100028 = ~"Warm yer weary bones at the hottest spot in the whole Hive!"~
@100029 = ~"A trip to the Ditch! Just 10 coppers!"~
@100030 = ~"Ooooh..."~
@100031 = ~"Bring happy currents to our kin..."~
@100032 = ~"Bring death to our enemies!"~
@100033 = ~"Chop-chop, yes-yes... Innards go slosh-slosh!"~
@100034 = ~"Glory to Istishia!"~
@100035 = ~"Glory to Baluu!"~
@100036 = ~"Glory to Dead Lady!"~
@100037 = ~"Glory to Sir Scar!"~
@100038 = ~*Howl*~
@100039 = ~"You sodding lizard!"~
@100040 = ~"This time, you're done for!"~
@100041 = ~"Tell me, abishai, did Tiamat stint on the red dye?"~
@100042 = ~"Grrr..."~
@100043 = ~"You don't even know how to cheat properly!"~
@100044 = ~"You flea-ridden mutt! Eat your words!"~
@100045 = ~"One day I'll sing 'O jubilant flames' on your grave."~
@100046 = ~*Nudge nudge, wink wink*~
@100047 = ~"Hey cutter, wanna have some fun?"~
@100048 = ~"Let's talk, handsome..."~
@100049 = ~"Listen carefully, I won't repeat..."~
@100050 = ~"Do you understand what I mean?"~
@100051 = ~"Arrow paradox, I told you about that before..."~
@100052 = ~"Oh wait, I think I get it..."~
@100053 = ~"I don't really get it, mate..."~
@100054 = ~"Right..."~
@100055 = ~*Hic!*~
@100056 = ~"Neeed an'thing, boss...?"~
@100057 = ~"Boss! Booooss!"~
@100058 = ~"The... The best tout in the whole bloody anthill!"~
@100059 = ~"Boss, gimme jink, and I'll give ye some directions!"~
@100060 = ~*Burp!*~
@100061 = ~"Thisss is a serious acc... accusation!"~
@100062 = ~"Oh, Sonne."~
@100063 = ~"Do you really love me?"~
@100064 = ~"Darling, please be honest with me."~
@100065 = ~"Do you not love me anymore?"~
@100066 = ~"Oh, Zack..."~
@100067 = ~"You know I really do love you."~
@100068 = ~"Why can't you see what I mean?"~
@100069 = ~"Love is not what you think it is."~
@100070 = ~"Are you ordering something? Or maybe you're interested in a bit of gambling?"~
@100071 = ~"Pint's up!"~
@100072 = ~"Here's your pint, berk!"~
@100073 = ~"There you go, mate!"~
@100074 = ~"One fresh pint for ya!"~
@100075 = ~"Mind your head, pint's coming through!"~
@100076 = ~"Wheat beer's up!"~
@100077 = ~"Avner's Abyssal Ale's up!"~
@100078 = ~"Baatezu Blood Wine's up!"~
@100079 = ~"Cranium rat race results are... "~
@100080 = ~"You over there, don't fight!"~
@100081 = ~"No open fires indoors! This ain't the 'Smoldering Corpse'!"~
@100082 = ~"Any news from the Blood War?"~
@100083 = ~"Slimes! Where are you?"~
@100084 = ~"One... Two..."~
@100085 = ~"Wait, is that a single slime? Or are there two really close together?"~
@100086 = ~"By Primus, it's so dirty here..."~
@100087 = ~"Cassie? Is that you?"~
@100088 = ~"Rawr!"~
@100089 = ~"Ahem. Rawr, I say."~
@100090 = ~"Be afraid!"~
@100091 = ~*Mutter*~
@100092 = ~*Mumble*~
@100093 = ~"Six... Seven... Damn, I slipped up again..."~
@100094 = ~"Pores... Bloody pores..."~
@100095 = ~"No! No! NO!!!"~
@100096 = ~"Die, perish!"~
@100097 = ~"You won't hurt me again!"~
@100098 = ~*Scream*~
@100099 = ~*Sigh*~
@100100 = ~*Heavy sigh*~
@100101 = ~*Giggle*~
@100102 = ~*Cackle*~
@100103 = ~*Snicker*~
@100104 = ~"Rats! Come to me, little rats!"~
@100105 = ~"I've got you!"~
@100106 = ~"No! Don't run away!"~
@100107 = ~"Gold!"~
@100108 = ~"Gooooold!"~
@100109 = ~"No gold...?"~
@100110 = ~"They're watching!"~
@100111 = ~"They can see me!"~
@100112 = ~"I feel your stare! I can't see it, but I can feel it!~
@100113 = ~"Eyes... I see eyes! In my mind!"~
@100114 = ~*Drip*~
@100115 = ~"Enlightenment is so close..."~
@100116 = ~"Once a drunkard from the Hive..."~
@100117 = ~"What should be the next line...?"~
@100118 = ~"Hive... What rhymes with Hive...?"~
@100119 = ~"Is this even seven syllables?"~
@100120 = ~"Alright, this might sound good..."~
@100121 = ~*Ahem*~
@100122 = ~"Alright, let's start over..."~
@100123 = ~"Um, excuse me?"~
@100124 = ~"Have you seen a girl in a red dress?"~
@100125 = ~"Don't look at me like that..."~
@100126 = ~"Pint's up!"~
@100127 = ~"Here's your pint!"~
@100128 = ~"Are you ordering something, biped?"~
@100129 = ~"There you go!"~
@100130 = ~"One fresh pint for ya!"~
@100131 = ~"Mind your head, pint's coming through!"~
@100132 = ~"Who ordered sunflower seed beer?"~
@100133 = ~"Corn beer's up!"~
@100134 = ~"What's the chant? Drink up and tell me."~
@100135 = ~"Damn men-fish! Have they struck our comrades again?"~
@100136 = ~"The Dead Nations spy? Scragged, I'm afraid."~
@100137 = ~"Look at that canny blood."~
@100138 = ~"Just what's the deal with that skeleton? I hope this greybeard's not from Hargrimm."~
@100139 = ~"Wait just a moment, I'll come to you."~
@100140 = ~"Does it hurt much?"~
@100141 = ~"Now, doesn't that make you feel better?"~
@100142 = ~"Easy! I'll deal with it."~
@100143 = ~"Pain, go away!"~
@100144 = ~"Who am I...?"~
@100145 = ~"Hey you! Do you happen to know me?"~
@100146 = ~"Who have I been this whole time?"~
@100147 = ~"I'm just a... Tiefling? That I know for sure..."~
@100148 = ~"This is Sigil, isn't it? Yeah, that's another thing I remember..."~
@100149 = ~"Sir! Spare some jink!"~
@100150 = ~"I need stones..."~
@100151 = ~"Do you have any stones?"~
@100152 = ~"I need so much more..."~
@100153 = ~"Look at the colors!"~
@100154 = ~"Mother!"~
@100155 = ~*Scream*~
@100156 = ~"Bipeds in the temple!"~
@100157 = ~"There will be blood!"~
@100158 = ~"Squerrik! Accept these treasures and this bloody sacrifice for your glory!"~
@100159 = ~"Kill all the bipeds!"~
@100160 = ~"Dear sir! Since you're already here, it wouldn't hurt to quickly sign this before the jump."~
@100161 = ~"A quick signature, then upsy-daisy and a golden future awaits in the land of angels!"~
@100162 = ~"Sir! Have you decided yet?"~
@100163 = ~"I understand, I understand. It's a difficult decision. But if you decide to make it, I'll be here waiting."~
@100164 = ~"Not good. The Takers have been sniffing around here..."~
@100165 = ~"Boss, I'm afraid there's no time for theater practice. We need to prepare for a battle."~
@100166 = ~"Woof!"~
@100167 = ~"Auuu!"~
@100168 = ~"Any news from Sigil?"~
@100169 = ~"Eat your fill! Tomorrow we fight again!"~
@100170 = ~"Pass me some boar meat."~
@100171 = ~"Fated! Fated! What makes right? Might does!"~
@100172 = ~"Prepare the bath and the sauna, I'll go there soon."~
@100173 = ~"Heill Óðinn! Sæl Óðinn!"~
@100174 = ~*Slurp*~
@100175 = ~*Slorp*~
@100176 = ~*WURR TURR*~
@100177 = ~"I can't wait for the tomorrow's battle."~
@100178 = ~"What a feast!"~
@100179 = ~"Might makes right!"~
@100180 = ~"Might! Might! Might!"~
@100181 = ~"Heill Óðinn!"~
@100182 = ~"Wanna trade?"~
@100183 = ~"I don't care who you are. Trade is the meaning of everything, cutter."~
@100184 = ~The crate seems to be magically sealed. There is a carving of a key next to the handle, but the details of it are gone due to water damage.~
@100185 = ~With the memory of the drawing from the book-mimic, the crate is now open.~
@100186 = ~"STEP RIGHT UP, TRY CRAB PUFFS TODAY! FUNKY LITTLE BITES THAT'LL BLOW YOU AWAY!"~
@100187 = ~"CRAB PUFFS, CRAB PUFFS, OOZY DELIGHT! QUESTION YOUR CHOICES WITH EVERY BITE!"~
@100188 = ~"GOT THE MUNCHIES? FEELING TOUGH? DARE YOUR TASTE BUDS, GRAB SOME CRAB PUFFS!"~
@100189 = ~"CRAB PUFFS HERE, DON'T BE SHY! YOU MIGHT REGRET IT... BUT AT LEAST YOU'LL TRY!"~
@100190 = ~*whew*~
@100191 = ~"Then there came along the float goats."~
@100192 = ~*CLAP CLAP*~
@100193 = ~"Am I still myself in my dreams?"~
@100194 = ~"How can I tell the difference 'tween a flame and a spark?"~
@100195 = ~"Interesting..."~
@100196 = ~^0xffFFFFFFJournal Updated^-~
@100197 = ~"DEATH!"~
@100198 = ~"The unfaithful will be punished. With DEATH!"~
@100199 = ~"Þetta var frábardagi."~
@100200 = ~"Ég held að ég hafi drepið að minnsta kosti tólf."~
@100201 = ~"Það var nánast eins og á fornum dögum."~
@100202 = ~"Það er leitt með fallna menn."~
@100203 = ~"Gaaaah!"~
@100204 = ~"Ouch, ouch, ouch!!!"~
@100205 = ~"Mooooommy!!!"~
@100206 = ~"Heeelp!!!"~
@100207 = ~"Eeeeeek!!!"~
@100208 = ~^0xffFFFFFFJournal Updated^-~
@100209 = ~"It's got to be around here somewhere..."~
@100210 = ~"Was it on this level?"~
@100211 = ~"My city needs me!"~
@100212 = ~"Perhaps I could..."~
@100213 = ~"Beautiful..."~
@100214 = ~*sniff sniff*~
@100215 = ~"Roses, roses!"~
@100216 = ~"Get yer flowers!"~
@100217 = ~"Raindrops on roses!"~
@100218 = ~"Whiskers on kittens!"~
@100219 = ~"Cats, cute cats."~
@100220 = ~"Ever wanted a friend that will eat you?"~
@100221 = ~"Bright copper kettles!"~
@100222 = ~"Stock your kitchen with me!"~
@100223 = ~"Pots and kettles!"~
@100224 = ~"Warm woolen mittens!"~
@100225 = ~"Cool, loose shirts."~
@100226 = ~"Clothes for all weather!"~
@100227 = ~"Brown paper packages!"~
@100228 = ~"Boxes! Only with me!"~
@100229 = ~"All things paper!"~
@100230 = ~"*STRIIING!*"~
@100231 = ~"Almost ready to set sail, last few seats!"~
@100232 = ~"Act like a sailor and make for me raft!"~
@100233 = ~"Hive-Ditch, Ditch-Hive, all day, every day!"~
@100234 = ~"You going back to the Smoldering Corpse?"~
@100235 = ~"Hey! Over here! I'll lead you to the center of the Hive."~
@100236 = ~"Hello, hello!"~
@100237 = ~The two halves of the Jade Skull are instantly drawn together and reform into one in a flash of green energy.~
@100238 = ~"Mighty Istishia, accept this sacrifice so that your blood ocean may spread forever. Yes-yes!"~
@100239 = ~"No! Please! I beg you!"~
@100240 = ~"Bloop, bloopidy, bloop-doop. Chop-chop."~
@100241 = ~"GLORY, GLORY TO ISTISHIA!"~
@100242 = ~"So, what should we do next?"~
@100243 = ~"I know! Let's sneak into the Prison!"~
@100244 = ~"How about we steal a key off Artus?"~
@100245 = ~"I'm bored."~
@100246 = ~"I wonder what's over the edge..."~
@100247 = ~"Waaaaah!"~
@100248 = ~*sniff*~
@100249 = ~"Eeeeeeaaah!"~
@100250 = ~^0x008000"Mister, stop. Something is wrong... Prod will..."^-~
@100251 = ~"Oi! That's the guy who killed the boss. Animator, come on over here!"~
@100253 = ~"Isn't this theater gorgeous?"~
@100256 = ~"I have nothing against comedy, but jokes should serve a purpose."~
@100257 = ~"No, I don't think it's justified to break the fourth wall here."~
@100258 = ~"Alright, that's actually quite interesting..."~
@100262 = ~"Shall we practice that again?"~
@100263 = ~"Again."~
@100264 = ~"I hope Kirinaldo is feeling better."~
@100265 = ~"Where's that understudy? He's late again."~
@100266 = ~"The Sigil Troupe is worthy of your attention and coin. I promise!"~
@100267 = ~"If we perform well, the Prime tour will finance itself."~

