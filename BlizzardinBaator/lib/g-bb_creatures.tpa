COPY ~%MOD_FOLDER%/cre/g-bb000.cre~ ~override~ 
 SAY NAME1 @400037 // Powiew Przeszlosci / Blast form the Past
 SAY NAME2 @400037
  WRITE_LONG 0x28 (IDS_OF_SYMBOL (~animate~ ~G-BB_ZOMBIE0~)) 
 WRITE_ASCII SCRIPT_OVERRIDE ~g-bbs001~ #8
 WRITE_ASCII DIALOG ~g-bbd000~ #8
 WRITE_ASCII DEATHVAR ~g-bb000~ #32
 WRITE_ASCII 0x34 ~JRZMMKN~
COPY_EXISTING ~AR0202.are~ ~override~
 LPF fj_are_structure
    INT_VAR
    fj_loc_x          = 1140
    fj_loc_y          = 2400
    fj_schedule       = 0b111111111111111111111111
    fj_orientation    = 10     //NNE
    STR_VAR
    fj_structure_type = actor
    fj_name           = g-bb000
    fj_cre_resref     = g-bb000
	
  END

COPY_EXISTING  // Tegarrin
 ~TEGAR'IN.cre~ ~override/TEGAR'IN.cre~
	WRITE_LONG 0x96 BIT4 + BIT5 + BIT6 // Atrtributes/Flags
