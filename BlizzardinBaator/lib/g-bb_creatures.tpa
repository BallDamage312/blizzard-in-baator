COPY ~%MOD_FOLDER%/cre/g-bb005.cre~ ~override~
 SAY NAME1 @400009 // Czarny Ziutek / Black Joseph 
 SAY NAME2 @400009
 WRITE_ASCII SCRIPT_OVERRIDE ~g-bbn010~ #8
 WRITE_ASCII DEATHVAR ~g-bb005~ #32
 WRITE_ASCII DIALOG ~g-bbd005~
 WRITE_BYTE 0x90 %thugscz%
 WRITE_ASCII 0x34 ~JRTLRKN~
 WRITE_LONG 0x14 ~3000~ // xp value
 WRITE_LONG 0x18 ~1~ // power level 
 WRITE_SHORT 0x24 ~75~ // current hp
 WRITE_SHORT 0x26 ~75~ // max hp
 WRITE_SHORT 0x46 ~-2~ // natural ac
 WRITE_SHORT 0x48 ~-2~ // effective ac
 WRITE_BYTE 0x52 ~8~ // THAC0
 WRITE_BYTE 0x59 ~30~ // Fire resist. 
 WRITE_BYTE 0x5a ~25~ // Cold resist.
 WRITE_BYTE 0x5c ~25~ // Acid resist.
 WRITE_BYTE 0x60 ~35~ // Slashing resist.
 WRITE_BYTE 0x61 ~30~ // Crushing resist.
 WRITE_BYTE 0x62 ~35~ // Piercing resist.
 WRITE_BYTE 0x63 ~30~ // Missle resist.
 WRITE_BYTE 0x234 ~18~ // Level first class
 WRITE_BYTE 0x278 ~17~ // Strenght
 WRITE_BYTE 0x23c ~16~ // Dexterity
 WRITE_BYTE 0x23d ~16~ // Constitution
 WRITE_BYTE 0x273 ~2~ // Class: fighter
 
