-- ==========================================================
-- 05. New factions and gods (Blizzard in Baator)
-- 1. Faction Registry
-- ==========================================================
customFactions = {
    {
        res   = "bam1",          -- max 8 char
        frame = 0,               
        desc  = t('first_bam'),      
        var   = "g-tno",  
        owner = "Nameless"           
    },
    {
        res   = "bam1 or bam2", 
        frame = 1, 
        desc  = t('second_bam'), 
        var   = "g-gem",
        owner = "Gemariel"           
    }
}

if not dgIdx then dgIdx = {1,1,1,1,1,1} end

function isCustomSystemActive()
    return isSpecialChar("Nameless") or isSpecialChar("Gemariel") or isSpecialChar("Furia")
end

-- ==========================================================
-- 2. Helper Functions (Internal Logic) 
-- ==========================================================

function getActiveModFactions()
    local active = {}
    local char = characters[currentID]
    if not char then return active end

    for _, f in ipairs(customFactions) do
        local isOwner = false
        -- Uproszczona logika właściciela
        if not f.owner or isSpecialChar(f.owner) then
            isOwner = true
        end

        if isOwner and Infinity_GetScriptVarInt(f.var) ~= 0 then 
            table.insert(active, f) 
        end
    end
    return active
end

function getValidOriginalFactions(char)
    local valid = {}
    if char and char.factions and char.factions.joinedFactions then
        for _, faction in ipairs(char.factions.joinedFactions) do
            if faction.frame and faction.frame ~= 0 then
                table.insert(valid, faction)
            end
        end
    end
    return valid
end

-- ==========================================================
-- 3. Display Logic (Resource, Frame, Tooltip)
-- ==========================================================

function getFactionRes()
    if not isCustomSystemActive() then return "STFCTION" end

    local activeMods = getActiveModFactions()
    local idx = dgIdx[currentID + 1] or 1
    
    if #activeMods > 0 and idx <= #activeMods then
        return activeMods[idx].res
    end
    return "STFCTION"
end

function getFactionFrame()
    local char = characters[currentID]
    if not char then return 0 end

    if not isCustomSystemActive() then
        local originals = getValidOriginalFactions(char)
        return originals[1] and originals[1].frame or 0
    end

    local activeMods = getActiveModFactions()
    local idx = dgIdx[currentID + 1] or 1
    
    if idx <= #activeMods then
        return activeMods[idx].frame
    end

    local originals = getValidOriginalFactions(char)
    local fIdx = idx - #activeMods
    return originals[fIdx] and originals[fIdx].frame or 0
end

function getFactionTooltip()
    local char = characters[currentID]
    if not char or not isCustomSystemActive() then return nil end

    local total = #getActiveModFactions() + #getValidOriginalFactions(char)

    if total > 1 then
        return Infinity_FetchString(67048)
    end
    return nil
end

-- ==========================================================
-- 4. Faction Description & Priority Validation
-- ==========================================================

function cycleCustomSystem(systemType)
    local char = characters[currentID]
    if not char then return end
    local activeElements = {}
    local originals = {}
    local globalIdxTable = nil
    if systemType == "faction" then
        activeElements = getActiveModFactions()
        originals = getValidOriginalFactions(char)
        globalIdxTable = dgIdx
    elseif systemType == "deity" then
        activeElements = getActiveDeities()
        originals = {}
        globalIdxTable = deityIdx
    end
    local total = #activeElements + #originals
    if total <= 1 then return end
    local currentIdx = globalIdxTable[currentID + 1] or 1
    currentIdx = currentIdx + 1
    if currentIdx > total then currentIdx = 1 end
    globalIdxTable[currentID + 1] = currentIdx
    if systemType == "faction" then
        setFactionHelp(currentIdx)
    elseif systemType == "deity" then
        setDeityHelp(currentIdx)
    end
    Infinity_PlaySound('int_10')
end

function setFactionHelp(forceIdx)
    local char = characters[currentID]
    if not char then return end
    
    local activeMods = getActiveModFactions()
    local idx = forceIdx or dgIdx[currentID + 1] or 1

    -- 1. Frakcje z moda
    if isCustomSystemActive() and idx <= #activeMods then
        recordHelpString = t('FACTION_GENERAL_DESCRIPTION') .. '\n\n' .. activeMods[idx].desc
        return
    end

    -- 2. Frakcje oryginalne
    local originals = getValidOriginalFactions(char)
    local fIdx = idx - #activeMods
    
    if originals[fIdx] then
        local descId = originals[fIdx].description
        recordHelpString = t('FACTION_GENERAL_DESCRIPTION') .. '\n\n' .. Infinity_FetchString(descId)
        return
    end

    -- 3. Failsafe (Niezrzeszony lub błąd indeksu)
    local current = char.factions.current
    if current and char.factions.joinedFactions and char.factions.joinedFactions[current] then
        local descId = char.factions.joinedFactions[current].description
        recordHelpString = t('FACTION_GENERAL_DESCRIPTION') .. '\n\n' .. Infinity_FetchString(descId)
    else
        recordHelpString = t('FACTION_GENERAL_DESCRIPTION')
    end
end

-- ==========================================================
-- 5. Deity Registry Table
-- ==========================================================
customDeities = {
    {
        res   = "g-bbgods", 
        frame = 0, 
        desc  = t('KIARANSALEE_DESC'), 
        var   = "G-kiaransaleefollower",
        owner = "Nameless"
    },
    {
        res   = "g-bbgods", 
        frame = 1, 
        desc  = t('DEITY_DESC_2'), 
        var   = "G_DEITY_B",
        owner = "Gemariel"
    }
}

if not deityIdx then deityIdx = {1,1,1,1,1,1} end

-- ==========================================================
-- 6. Deity System Logic
-- ==========================================================

function getActiveDeities()
    local active = {}
    for _, d in ipairs(customDeities) do
        local isOwner = (not d.owner or isSpecialChar(d.owner))
        if isOwner and Infinity_GetScriptVarInt(d.var) ~= 0 then 
            table.insert(active, d) 
        end
    end
    return active
end

function getDeityRes()
    if not isCustomSystemActive() then return "" end 
    local active = getActiveDeities()
    local idx = deityIdx[currentID + 1] or 1
    
    if #active > 0 and idx <= #active then
        return active[idx].res
    end
    return ""
end

function getDeityFrame()
    if not isCustomSystemActive() then return 0 end
    local active = getActiveDeities()
    local idx = deityIdx[currentID + 1] or 1
    
    if #active > 0 and idx <= #active then
        return active[idx].frame
    end
    return 0
end

function getDeityTooltip()
    if not isCustomSystemActive() then return nil end
    local activeCount = #getActiveDeities()
    if activeCount >= 1 then
        return t('TOOLTIP_DEITY_GENERAL') 
    end
    return nil
end

function setDeityHelp(forceIdx)
    local char = characters[currentID]
    if not char then return end

    local active = getActiveDeities()
    
    if #active == 0 then 
        return 
    end

    local idx = forceIdx or deityIdx[currentID + 1] or 1

    if isCustomSystemActive() and idx <= #active then
        recordHelpString = t('DEITY_GENERAL') .. '\n\n' .. active[idx].desc
    end
end
