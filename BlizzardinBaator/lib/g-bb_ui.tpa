   menu
   {
   name 'CHAPTER'
   align center center
   ignoreEsc

   label
   {
		area 0 0 1024 768
		mosaic lua "chapterBackground"
   }
   text
   {
		name "text_CHAPTERSCROLL_item"
		area 196 470 632 224
		text lua "text_CHAPTERSCROLL"
		text style "white_parchment"
		scrollbar 'cgscrl1'
		scrollbar func 'UpdateChapterScroll'
		scrollbar hide lua 'text_CHAPTERSCROLL_auto == 1'
		action
		"
		text_CHAPTERSCROLL_auto = 0
		"
   }
   button
   {
		area 330 714 377 44
		bam NORMBUTT
		text "QUIT_BUTTON"
		text style "button"
		clickable lua "chapterScreen:IsDoneButtonClickable()"
		action
		"
		 --chapterScreen:OnDoneButtonClick()
        
        popup3Button(69333, 
            'CANCEL_BUTTON', nil, 
            'QUIT_BUTTON', function() optionsScreen:QuitGame() end, 
            'SAVE_BUTTON', function() optionsScreen:SaveGame(0) end
            ) 
		"
   }
}

   menu
   {
   name 'EPILOGUE'
   ~

 REPLACE_TEXTUALLY ~onOpen[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+pushSidebars()[%TAB%%LNL%%MNL%%WNL% ]+resetRecordHelpString()[%TAB%%LNL%%MNL%%WNL% ]+Infinity_SetBackground('BACKGROUND_RECORD')[%TAB%%LNL%%MNL%%WNL% ]+"~
~onOpen
    "    
        pushSidebars()
		resetRecordHelpString()
		--setFactionHelp()
		--setDeityHelp()
        --validateFactionIndex()
        Infinity_SetBackground('BACKGROUND_RECORD')
    "~ //gemini

 REPLACE_TEXTUALLY ~text[%TAB%%LNL%%MNL%%WNL%]+{[541 479 123 122%TAB%%LNL%%MNL%%WNL% ]+area 541 479 123 122[%TAB%%LNL%%MNL%%WNL% ]+bam "STFCTION"[%TAB%%LNL%%MNL%%WNL% ]+frame lua "getFactionFrame()"[%TAB%%LNL%%MNL%%WNL% ]+tooltip lua "getFactionTooltip()"[%TAB%%LNL%%MNL%%WNL% ]+ignoreFocus lua "getFactionTooltip() == nil"[%TAB%%LNL%%MNL%%WNL% ]+actionEnter[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+setFactionHelp()[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+actionExit[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+resetRecordHelpString()[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+action[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+local factionCount = #characters\[currentID\].factions.joinedFactions[%TAB%%LNL%%MNL%%WNL% ]+local current = characters\[currentID\].factions.current[%TAB%%LNL%%MNL%%WNL% ]+if(factionCount > 1) then[%TAB%%LNL%%MNL%%WNL% ]+Infinity_PlaySound('int_10')[%TAB%%LNL%%MNL%%WNL% ]+if(current < factionCount) then[%TAB%%LNL%%MNL%%WNL% ]+characters\[currentID\].factions.current = current \+ 1[%TAB%%LNL%%MNL%%WNL% ]+else[%TAB%%LNL%%MNL%%WNL% ]+characters\[currentID\].factions.current = 1[%TAB%%LNL%%MNL%%WNL% ]+end[%TAB%%LNL%%MNL%%WNL% ]+end[%TAB%%LNL%%MNL%%WNL% ]+setFactionHelp()[%TAB%%LNL%%MNL%%WNL% ]+"[%TAB%%LNL%%MNL%%WNL% ]+}~
 
 ~text
{
    area 541 479 123 122
    bam "STFCTION"              -- Default fallback BAM
    frame lua "getFactionFrame()"
    bam lua "getFactionRes()"   -- Dynamic BAM override
    tooltip lua "getFactionTooltip()"
    
    -- Interaction only if multiple factions exist
    ignoreFocus lua "getFactionTooltip() == nil"
    
    actionEnter
    "
        setFactionHelp()
    "
    actionExit
    "
        if resetRecordHelpString then resetRecordHelpString() else recordHelpString = '' end
    "
   action
	"
    if isCustomSystemActive() then
        cycleCustomSystem('faction')
    end
	"
}
text
{
    area 0 479 123 122
    enabled "#getActiveDeities() > 0"
    
    bam lua "getDeityRes()"
    frame lua "getDeityFrame()"
    tooltip lua "getDeityTooltip()"
    
    ignoreFocus lua "getDeityTooltip() == nil"
    
    actionEnter "setDeityHelp()"
    actionExit "if resetRecordHelpString then resetRecordHelpString() else recordHelpString = '' end"
    
     action
	"
    if isCustomSystemActive() then
        cycleCustomSystem('deity')
    end
	"
}~
	
