COPY_EXISTING ~L_en_US.lua~ ~override~
	REPLACE_TEXTUALLY ~SHOW_CHEATS_BUTTON = "Show",~ 
~SHOW_CHEATS_BUTTON = "Show",

	-- G-Blizzard in Baator (story mod)
	GEMARIEL_CLASS = "Cleric / Mage",
	GEMARIEL_BIO = "Testowa biografia gemariela \n\neng.",
	FURY_BIO = "furia bio test.",
	GEMARIEL_WS =  "The claws are part of Gemariel. They cannot be removed.",
	GEMARIEL_WS_TOOLTIP = "Gemariel's Claws",
	GEMARIEL_WS_ITEM_NAME = "Gemariel's Claws",
	GEMARIEL_WS_ITEM_DESC = "GEMARIEL'S CLAWS \n(Default Weapon) \nDamage: 1-8, piercing or slashing \nEnchantment: +1 \nSpeed: 1 \nWeight: 0 \nProficiency: Fists \n\n \nAbishai claws are razor-sharp, fast, and deadly, but above all, effective. They are the Gemariel's primary weapon, enhanced with a touch of Set's magic. What more could an Abishai of this kind want from life?",
	DEITY_GENERAL = "WORSHIP \n\nBelief is one of the fundamental forces shaping the Planes. There are dozens of pantheons and hundreds of Powers worshiped by their inhabitants",
	TOOLTIP_DEITY_GENERAL ="",
	KIARANSALEE_DESC = "Current worship: Kiaransalee\n(Lady of the Dead, The Revenancer, The Vengeful Banshee or The Pitiless Dowager) \n\nA Chaotic Evil deity of undeath and vengeace, member of the drow pantheon (Dark Seldarine). Her divine realm is situated in Thanatos, Abyss.\nHer mission is to extinguish all life in the Planes so there can be peace and equality, forever.",~
	


COPY_EXISTING ~L_en_US.lua~ ~override/L_pl_PL.lua~
	REPLACE_TEXTUALLY ~GEMARIEL_CLASS[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_CLASS = "Kapłan / Mag",~
	
	REPLACE_TEXTUALLY ~GEMARIEL_BIO[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_BIO = "Testowa biografia gemariela \n\npl.",~
	
	REPLACE_TEXTUALLY ~FURY_BIO[ ]*=[ ]*"[^"]*",?~ ~FURY_BIO = "furia bio test pl.",~
	
	REPLACE_TEXTUALLY ~GEMARIEL_WS[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_WS = "Pazury są częścią Gemariela. Nie możesz ich zdjąć.",~
	
	REPLACE_TEXTUALLY ~GEMARIEL_WS_TOOLTIP[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_WS_TOOLTIP = "Pazury Gemariela",~
	
	REPLACE_TEXTUALLY ~GEMARIEL_WS_ITEM_NAME[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_WS_ITEM_NAME = "Pazury Gemariela",~
	
	REPLACE_TEXTUALLY ~GEMARIEL_WS_ITEM_DESC[ ]*=[ ]*"[^"]*",?~ ~GEMARIEL_WS_ITEM_DESC = "PAZURY GEMARIELA \n(Standardowa broń) \nObrażenia: 1-8, kłute lub sieczne \nUmagicznienie: +1 \nSzybkość: 1 \nWaga: 0 \nBiegłość: Pięści \n\n \nPazury abiszaja - ostre jak brzytwa, szybkie i zabójcze, ale przede wszystkim skuteczne. To podstawowa broń Gemariela, zaprawiona nutką magii Seta. Czegóż abiszai tego pokroju może chcieć więcej od życia?",~	
	
	REPLACE_TEXTUALLY ~DEITY_GENERAL[ ]*=[ ]*"[^"]*",?~ ~DEITY_GENERAL = "WYZNANIE \n\nWiara jest jedną z głównych sił poruszających Sfery. Istnieją dziesiątki panteonów i setki Mocy, które wyznają ich mieszkańcy.",~
	
	REPLACE_TEXTUALLY ~TOOLTIP_DEITY_GENERAL[ ]*=[ ]*"[^"]*",?~ ~TOOLTIP_DEITY_GENERAL = "",~
	
	REPLACE_TEXTUALLY ~KIARANSALEE_DESC[ ]*=[ ]*"[^"]*",?~ ~KIARANSALEE_DESC = "Bieżące wyznanie: Kiaransalee\n(Mścicielka, Mściwa Banshee, Biała Banshee) \n\nChaotyczna Zła bogini nieśmierci i zemsty należąca do panteonu mrocznych elfów (Mroczne Seldarine). Jej święta kraina znajduje się w Thanatos w Otchłani.\nJej misją jest zgaszenie wszelkiego życia w Sferach aby mogła zapanować równość i spokój, na zawsze.",~


