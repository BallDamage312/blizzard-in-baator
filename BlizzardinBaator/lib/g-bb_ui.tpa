-- ==========================================================
-- 04. Variuos functions (Blizzard in Baator)
-- ==========================================================
	
-- Centralized Portrait & Role Management
function isPortrait(name)
    local char = characters[currentID]
    if not char or not char.portrait then return false end
    return string.lower(char.portrait) == string.lower(name)
end

function isSpecialChar(roleName)
    local roles = {
        ["Nameless"] = "wmpnam1",
        ["Gemariel"] = "g-00gem",
        ["Furia"]    = "wmpfury"
    }

    local target = roles[roleName]
    if not target then return false end

 
    if not id or not characters or not characters[id] then 
        return false 
    end
    
    local char = characters[id]
    if not char.portrait then return false end

    local currentPort = string.lower(char.portrait):gsub("%.bmp", "")
    local lookFor = string.lower(target):gsub("%.bmp", "")

    return currentPort == lookFor
end

function getDynamicBio()
    if isSpecialChar('Gemariel') then 
        return t('GEMARIEL_BIO')
    end
    
    if isSpecialChar('Furia') then 
       return t('FURY_BIO')
    end
    
    return ""
end

function getBBClass()
    if isSpecialChar('Gemariel') then
        return t('GEMARIEL_CLASS')
    end
    return nil
end

