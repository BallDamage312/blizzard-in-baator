 LAF FIND_FREE_ANIM_SLOT INT_VAR slotMin = 0xF101 RET slot END
  ACTION_IF (slot <= 0) BEGIN
    FAIL ~No free creature animation slot found.~
  END

  LAF TO_HEX_NUMBER INT_VAR value = slot minDigits = 4 RET hexNumber END
  APPEND ~animate.ids~ ~0x%hexNumber% G-BB_RAELIS~ UNLESS ~G-BB_RAELIS~
  CLEAR_IDS_MAP

  COPY ~%MOD_FOLDER%/bam/animations/035.raelis/g-.ini~ ~override/%hexNumber%.ini~
  REPLACE_TEXTUALLY ~\(bestiary[ %TAB%]*\)=.*~ ~\1=%bestiary_index_020%~
  BUT_ONLY
  
  //OUTER_SPRINT "hexNumber20" ~%hexNumber%~
  
  ACTION_BASH_FOR ~%MOD_FOLDER%/bam/animations/035.raelis~ ~^.+\.bam$~ BEGIN
    COPY ~%BASH_FOR_FILESPEC%~ ~override~
  END
  
		//COPY_EXISTING ~%hexNumber20%.ini~ ~override~
		COPY_EXISTING ~bgee.lua~ ~override~
		
		SET name_raelis = RESOLVE_STR_REF(@400043)
		SET desc_raelis = RESOLVE_STR_REF(@800020)
		
        TEXT_SPRINT INDENT ~%TAB%%TAB%%TAB%  ~
        PATCH_IF (max_index > 0) BEGIN
          SET bestiary_index = max_index + 20
          TEXT_SPRINT new_entry ~%TAB%},%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%TAB%{%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%index=%bestiary_index%,%WNL%~
		  TEXT_SPRINT new_entry ~%new_entry%%INDENT%killvar='g-bb054',%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%desc0=%desc_raelis%,%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%class=1,%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%imageUnknown='image',%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%imageKnown='g-bbj020',%WNL%~
          TEXT_SPRINT new_entry ~%new_entry%%INDENT%name=%name_raelis%,%WNL%~
          SET strlen = STRING_LENGTH ~%new_entry%~
          INSERT_BYTES ofs_end strlen
          WRITE_ASCIIE ofs_end ~%new_entry%~ (strlen)
		END ELSE BEGIN
      PATCH_LOG ~Warning: Could not add Raeli Shai bestiary entry.~
    END
BUT_ONLY


