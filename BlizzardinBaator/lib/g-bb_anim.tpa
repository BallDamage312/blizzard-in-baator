
//////////////////////////////
// ======================== //
// Animations with Bestiary //
// ======================== //
//////////////////////////////

INCLUDE ~%MOD_FOLDER%/utils/functions.tph~
INCLUDE ~%MOD_FOLDER%/utils/a7_psteebestiary.tph~
COPY ~%MOD_FOLDER%/misc/port_bmp~ ~override~

// Prod

	ACTION_IF (max_index > 0) BEGIN
    OUTER_SET bestiary_index_001 = max_index + 1
    OUTER_TEXT_SPRINT bestiary_index_str ~%bestiary_index_001%~
	END

 LAF FIND_FREE_ANIM_SLOT INT_VAR slotMin = 0xF101 RET slot END
  ACTION_IF (slot <= 0) BEGIN
    FAIL ~No free creature animation slot found.~
  END

  LAF TO_HEX_NUMBER INT_VAR value = slot minDigits = 4 RET hexNumber END
  APPEND ~animate.ids~ ~0x%hexNumber% G-BB_PROD~ UNLESS ~G-BB_PROD~
  CLEAR_IDS_MAP

  COPY ~%MOD_FOLDER%/bam/animations/002.prod/g-.ini~ ~override/%hexNumber%.ini~
  REPLACE_TEXTUALLY ~\(bestiary[ %TAB%]*\)=.*~ ~\1=%bestiary_index_001%~
  BUT_ONLY
  
  ////OUTER_SPRINT "hexNumber1" ~%hexNumber%~

  ACTION_BASH_FOR ~%MOD_FOLDER%/bam/animations/002.prod~ ~^.+\.bam$~ BEGIN
    COPY ~%BASH_FOR_FILESPEC%~ ~override~
  END

	////COPY_EXISTING ~%hexNumber1%.ini~ ~override~
	COPY_EXISTING ~bgee.lua~ ~override~
	
	SET name_prod = RESOLVE_STR_REF(@400010)
    SET desc_prod = RESOLVE_STR_REF(@800001)
	
    TEXT_SPRINT INDENT ~%TAB%%TAB%%TAB%  ~
	PATCH_IF (max_index > 0) BEGIN
	SET bestiary_index = max_index + 1
      TEXT_SPRINT new_entry ~%TAB%},%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%TAB%{%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%index=%bestiary_index%,%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%killvar='g-bb006',%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%desc0=%desc_prod%,%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%class=1,%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%imageUnknown='image',%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%imageKnown='g-bbj001',%WNL%~
      TEXT_SPRINT new_entry ~%new_entry%%INDENT%name=%name_prod%,%WNL%~

      SET strlen = STRING_LENGTH ~%new_entry%~
      INSERT_BYTES ofs_end strlen
      WRITE_ASCIIE ofs_end ~%new_entry%~ (strlen)
    END ELSE BEGIN
      PATCH_LOG ~Warning: Could not add Prod bestiary entry.~
    END
BUT_ONLY

