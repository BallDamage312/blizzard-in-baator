    RET
      original_base_index
      new_base_index
  END

ACTION_IF (new_base_index >= 0) BEGIN
  // Installing PVRZ resources
  ACTION_FOR_EACH file IN ~MOS0000.pvrz~ ~MOS0001.pvrz~ BEGIN
    LAF INSTALL_PVRZ
      INT_VAR
        original_base_index
        new_base_index
      STR_VAR
        source_file = EVAL ~%MOD_FOLDER%/mos/v2/wmps/ditch/%file%~
      RET
        success
		
    END
    ACTION_IF (NOT success) BEGIN 
      WARN ~Could not install file %file%!~
    END
  END
END
END

