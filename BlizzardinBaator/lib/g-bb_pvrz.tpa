
// *** Code author: Argent77 ***

////////////
// ====== //
//  WMPS  //
// ====== //
////////////

ACTION_IF GAME_IS ~pstee~ BEGIN
// Installing BAM resource
// the ditch
COPY ~%MOD_FOLDER%/bam/bam+pvrz/wmps_icons/ditch/g-ditch.bam~ ~override~
  LPF UPDATE_PVRZ_INDICES
    RET
      original_base_index
      new_base_index
  END

// It is strongly recommended to check the return values of "UPDATE_PVRZ_INDICES".
// the ditch
ACTION_IF (new_base_index >= 0) BEGIN
  // Installing associated PVRZ resources
  ACTION_FOR_EACH file IN ~MOS1000.pvrz~ BEGIN
    LAF INSTALL_PVRZ
      INT_VAR
        original_base_index
        new_base_index
      STR_VAR
        source_file = EVAL ~%MOD_FOLDER%/bam/bam+pvrz/wmps_icons/ditch/%file%~
      RET
        success
        /*DEST_FILE
    END
    ACTION_IF (success) BEGIN
      PRINT ~Successfully installed file %file% as %DEST_FILE%.~*/
	  END
	     ACTION_IF (NOT success) BEGIN 
      WARN ~Could not install file %file%!~
    END
  END
END
END

// Installing MOS
// the ditch
